---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroVideo from '../../components/HeroVideo.astro';
---

<BaseLayout
  title="Fishing Pond"
  description="Fishing pond at Otter Valley — stocked pond and annual trout derby for children."
>

  <HeroVideo
    compact={true}
    title="Fishing Pond"
    tagline="Cast a line. Enjoy the quiet."
    backgroundImage="/images/club/fishing-pond-01.jpg"
  />

  <!-- Overview -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">A Quiet Corner of 50 Acres</h2>
      <hr class="gold-divider" />
      <p style="max-width: 760px; margin: 0 auto 1rem;">
        The club's fishing pond is a peaceful retreat tucked within the 50-acre Otter Valley property.
        Whether you're looking for a quiet morning with a rod in hand or bringing the kids out for
        their first fishing experience, the pond offers a relaxed escape from the shooting ranges.
      </p>
      <p style="max-width: 760px; margin: 0 auto;">
        The pond is also home to the club's beloved Annual Trout Derby — a free event for children
        that has drawn over 100 young anglers in recent years.
      </p>
    </div>
  </section>

  <!-- Access & Hours -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Member Access</h2>
      <hr class="gold-divider" />
      <div style="max-width: 700px; margin: 0 auto;">
        <div class="card access-card">
          <div class="access-row">
            <div class="access-block">
              <span class="access-label">Hours</span>
              <span class="access-value">Dawn to Dusk</span>
            </div>
            <div class="access-divider"></div>
            <div class="access-block">
              <span class="access-label">Access</span>
              <span class="access-value">General member access</span>
            </div>
            <div class="access-divider"></div>
            <div class="access-block">
              <span class="access-label">Location</span>
              <span class="access-value">On the main property</span>
            </div>
          </div>
          <p class="access-note">
            The pond is accessible to all club members during daylight hours. The property is located
            between Eden and Straffordville at 9908 Plank Road (formerly Hwy&nbsp;#19).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trout Derby -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Annual Trout Derby</h2>
      <hr class="gold-divider" />
      <p style="max-width: 720px; margin: 0 auto 2rem; text-align: center;">
        One of Otter Valley's most anticipated events of the year — a free fishing derby open to
        children 15 and under, stocked with rainbow trout, and supported by local businesses.
      </p>

      <div class="card text-center" style="max-width: 600px; margin: 0 auto; padding: 2rem;">
        <p style="font-size: 1rem; margin-bottom: 0.75rem;">
          The Annual Trout Derby is a free fishing event for children, stocked with rainbow trout
          and supported by local businesses. It's one of the club's most popular community events.
        </p>
        <p style="font-size: 0.9rem; opacity: 0.7; margin-bottom: 0;">
          Details for the next derby — including date, time, and age requirements — will be posted here
          and on <a href="https://www.facebook.com/OtterValleyRodandGunClub/" target="_blank" rel="noopener noreferrer">our Facebook page</a> when available.
        </p>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Finding Us</h2>
      <hr class="gold-divider" />
      <div style="max-width: 680px; margin: 0 auto; text-align: center;">
        <p style="font-size: 1.1rem; margin-bottom: 0.5rem;">
          9908 Plank Road (formerly Hwy&nbsp;#19)
        </p>
        <p style="opacity: 0.8;">
          Between Eden and Straffordville, Ontario
        </p>
        <p style="margin-top: 1.5rem; opacity: 0.85; font-size: 0.95rem;">
          The fishing pond is situated on the main 50-acre property. Follow the club driveway
          from Plank Road — parking is available near the clubhouse and the pond is accessible
          on foot from there.
        </p>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Gallery</h2>
      <hr class="gold-divider" />
      <div class="gallery-grid">
        <div class="gallery-item gallery-item-wide">
          <img src="/images/club/fishing-pond-01.jpg" alt="Otter Valley fishing pond" loading="lazy" />
        </div>
      </div>
      <p class="gallery-note text-center">
        Photos from recent Trout Derby events coming soon.
      </p>
    </div>
  </section>

  <!-- Other Disciplines -->
  <section class="section">
    <div class="container text-center">
      <h2>Explore Other Disciplines</h2>
      <hr class="gold-divider" />
      <div class="discipline-links">
        <a href="/disciplines/trap/" class="btn btn-gold">Trap Shooting</a>
        <a href="/disciplines/sporting-clays/" class="btn btn-gold">Sporting Clays</a>
        <a href="/disciplines/rifle/" class="btn btn-gold">Rifle</a>
        <a href="/disciplines/handgun/" class="btn btn-gold">Handgun</a>
        <a href="/disciplines/archery/" class="btn btn-gold">Archery</a>
      </div>
      <div class="mt-4">
        <a href="/membership/" class="btn btn-gold">Join the Club</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Access card */
  .access-card {
    padding: 1.75rem 2rem;
  }

  .access-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: stretch;
    margin-bottom: 1.25rem;
  }

  .access-block {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 130px;
  }

  .access-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--gold-dark);
  }

  .access-value {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--cream-light);
  }

  .access-divider {
    width: 1px;
    background: rgba(93, 64, 55, 0.5);
    align-self: stretch;
  }

  @media (max-width: 600px) {
    .access-divider { display: none; }
  }

  .access-note {
    font-size: 0.88rem;
    opacity: 0.8;
    margin-bottom: 0;
    border-top: 1px solid rgba(93, 64, 55, 0.4);
    padding-top: 1rem;
  }

  /* Derby stat cards */
  .derby-stat-card {
    padding: 1.5rem 1rem;
  }

  .derby-stat-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .derby-stat-card h4 {
    margin-bottom: 0.5rem;
  }

  .derby-stat {
    font-size: 1rem;
    font-weight: 600;
    color: var(--cream-light);
    margin-bottom: 0.2rem;
  }

  .derby-substat {
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 0;
  }

  /* Results cards */
  .results-card {
    padding: 1.25rem 1.5rem;
  }

  .results-year {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--gold);
    margin-bottom: 0.15rem;
  }

  .results-date {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.65;
    margin-bottom: 0.75rem;
  }

  /* Spec table (shared with archery but scoped here too) */
  .spec-table {
    width: 100%;
  }

  .spec-table th {
    background: transparent;
    color: var(--gold);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.45rem 0.6rem;
    width: 42%;
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
    cursor: default;
    user-select: text;
  }

  .spec-table td {
    font-family: var(--font-body);
    font-size: 0.88rem;
    padding: 0.45rem 0.6rem;
    color: var(--cream);
    border-bottom: 1px solid rgba(93, 64, 55, 0.3);
  }

  .spec-table tr:nth-child(even) {
    background: rgba(27, 14, 0, 0.3);
  }

  .spec-table tr:hover {
    background: rgba(201, 168, 76, 0.06);
  }

  /* Gallery */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto 1rem;
  }

  .gallery-item {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--brown-light);
    background: var(--brown-dark);
  }

  .gallery-item-wide {
    aspect-ratio: 16 / 9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  .gallery-note {
    font-size: 0.82rem;
    opacity: 0.55;
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  /* Other disciplines links */
  .discipline-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
  }
</style>
