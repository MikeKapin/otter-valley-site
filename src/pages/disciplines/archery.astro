---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroVideo from '../../components/HeroVideo.astro';
---

<BaseLayout
  title="Archery"
  description="Archery at Otter Valley — indoor 20-yard range and outdoor 3D target stations."
>

  <HeroVideo
    compact={true}
    title="Archery"
    tagline="Traditional skill. Modern range."
    backgroundImage="/images/club/archery-range-01.jpg"
  />

  <!-- Overview -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">About the Archery Program</h2>
      <hr class="gold-divider" />
      <p style="max-width: 760px; margin: 0 auto 1rem;">
        Archery has been a discipline at Otter Valley for as long as anyone can remember. The program
        welcomes competition shooters, hobbyists, and hunters alike — whether you shoot traditional
        recurve, compound, or crossbow.
      </p>
      <p style="max-width: 760px; margin: 0 auto;">
        Both indoor and outdoor facilities are available, giving members year-round access regardless
        of Ontario's often unpredictable weather.
      </p>
    </div>
  </section>

  <!-- Facilities -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Facilities</h2>
      <hr class="gold-divider" />
      <div class="grid-2">

        <div class="card">
          <h3>Indoor Range</h3>
          <p class="facility-subtitle">Located inside the clubhouse</p>
          <table class="spec-table">
            <tbody>
              <tr>
                <th>Distance</th>
                <td>20 yards</td>
              </tr>
              <tr>
                <th>Capacity</th>
                <td>8 archers simultaneously</td>
              </tr>
              <tr>
                <th>Equipment</th>
                <td>Portable tin-test butt (wheeled)</td>
              </tr>
              <tr>
                <th>Safety</th>
                <td>Safety curtain provided</td>
              </tr>
            </tbody>
          </table>
          <p class="facility-note">
            The portable butt must be returned to its stored position after use to keep the space
            clear for handgun and small bore shooting.
          </p>
        </div>

        <div class="card">
          <h3>Outdoor Facilities</h3>
          <p class="facility-subtitle">Grounds west of the clubhouse</p>
          <table class="spec-table">
            <tbody>
              <tr>
                <th>Practice Butt</th>
                <td>Single butt at pistol range</td>
              </tr>
              <tr>
                <th>3D Targets</th>
                <td>Five stations (follow hydro lines)</td>
              </tr>
              <tr>
                <th>Accepted Styles</th>
                <td>Traditional, compound, crossbow</td>
              </tr>
            </tbody>
          </table>
          <p class="facility-note">
            The 3D target course runs west of the clubhouse along the hydro line corridors — follow
            the posted markers from the main parking area.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Rules -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Range Rules</h2>
      <hr class="gold-divider" />
      <div class="rules-grid">

        <div class="card rule-card rule-critical">
          <div class="rule-icon">&#9888;</div>
          <h4>Field Tips Only</h4>
          <p>
            <strong>No broadheads are permitted anywhere on club property.</strong> This rule applies
            to all ranges and the 3D target course without exception.
          </p>
        </div>

        <div class="card rule-card">
          <div class="rule-icon">&#127993;</div>
          <h4>Equipment</h4>
          <p>
            Traditional archery equipment, compound bows, and crossbows are all welcome. Ensure
            all equipment is in safe, serviceable condition before shooting.
          </p>
        </div>

        <div class="card rule-card">
          <div class="rule-icon">&#127968;</div>
          <h4>Indoor Range Etiquette</h4>
          <p>
            Return the portable butt to its stored position after each session. This keeps the
            indoor space available for handgun and small bore use between archery bookings.
          </p>
        </div>

        <div class="card rule-card">
          <div class="rule-icon">&#127807;</div>
          <h4>3D Course Access</h4>
          <p>
            Follow the hydro lines west of the clubhouse to reach the five 3D target stations.
            Stay on marked paths and respect the natural surroundings of the 50-acre property.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Schedule</h2>
      <hr class="gold-divider" />
      <div style="max-width: 600px; margin: 0 auto;">
        <div class="card schedule-card">
          <div class="schedule-row">
            <span class="schedule-day">Monday Evenings</span>
            <span class="schedule-time">Starting around 6:30 PM</span>
          </div>
          <p style="margin-top: 1rem; margin-bottom: 0; opacity: 0.85; font-size: 0.95rem;">
            Regular Monday evening shoots run throughout the season. New and prospective members
            are welcome to come out and observe. Contact the archery coordinators below for
            current seasonal information.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Archery Coordinators</h2>
      <hr class="gold-divider" />
      <div class="grid-2" style="max-width: 800px; margin: 0 auto;">

        <div class="card contact-card">
          <h4>Mark Hopper</h4>
          <p class="contact-detail">
            <span class="contact-label">Phone</span>
            <a href="tel:5198665440">519-866-5440</a>
          </p>
          <p class="contact-detail" style="margin-bottom: 0;">
            <span class="contact-label">Email</span>
            <a href="mailto:hoppermt@outlook.com">hoppermt@outlook.com</a>
          </p>
        </div>

        <div class="card contact-card">
          <h4>Michael Gosselin</h4>
          <p class="contact-detail">
            <span class="contact-label">Phone</span>
            <a href="tel:5196880061">519-688-0061</a>
          </p>
          <p class="contact-detail" style="margin-bottom: 0;">
            <span class="contact-label">Email</span>
            <a href="mailto:gosselin2018@rogers.com">gosselin2018@rogers.com</a>
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Gallery</h2>
      <hr class="gold-divider" />
      <div class="gallery-grid">
        <div class="gallery-item">
          <img src="/images/club/archery-range-01.jpg" alt="Otter Valley archery range" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/club/archery-range-02.jpg" alt="Archery range — second view" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/club/archery-range-03.jpg" alt="Archery range — third view" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Other Disciplines -->
  <section class="section section-dark">
    <div class="container text-center">
      <h2>Explore Other Disciplines</h2>
      <hr class="gold-divider" />
      <div class="discipline-links">
        <a href="/disciplines/trap/" class="btn btn-gold">Trap Shooting</a>
        <a href="/disciplines/sporting-clays/" class="btn btn-gold">Sporting Clays</a>
        <a href="/disciplines/rifle/" class="btn btn-gold">Rifle</a>
        <a href="/disciplines/handgun/" class="btn btn-gold">Handgun</a>
        <a href="/disciplines/fishing/" class="btn btn-gold">Fishing Pond</a>
      </div>
      <div class="mt-4">
        <a href="/membership/" class="btn btn-gold">Join the Club</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Facility tables */
  .spec-table {
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .spec-table th {
    background: transparent;
    color: var(--gold);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 0.75rem;
    width: 40%;
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
    cursor: default;
    user-select: text;
  }

  .spec-table td {
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    color: var(--cream);
    border-bottom: 1px solid rgba(93, 64, 55, 0.3);
  }

  .spec-table tr:nth-child(even) {
    background: rgba(27, 14, 0, 0.3);
  }

  .spec-table tr:hover {
    background: rgba(201, 168, 76, 0.06);
  }

  .facility-subtitle {
    font-size: 0.85rem;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gold-light);
    margin-bottom: 0.5rem;
  }

  .facility-note {
    font-size: 0.85rem;
    opacity: 0.8;
    margin-bottom: 0;
    border-top: 1px solid rgba(93, 64, 55, 0.4);
    padding-top: 0.75rem;
    margin-top: 0.25rem;
  }

  /* Rules grid */
  .rules-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .rules-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .rule-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rule-card p {
    margin-bottom: 0;
    font-size: 0.9rem;
  }

  .rule-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .rule-critical {
    border-color: var(--gold-dark);
    background: rgba(139, 0, 0, 0.12);
  }

  .rule-critical h4 {
    color: #e57373;
  }

  /* Schedule */
  .schedule-card {
    padding: 1.5rem 2rem;
  }

  .schedule-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    justify-content: space-between;
  }

  .schedule-day {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--gold);
  }

  .schedule-time {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--cream-light);
    background: rgba(201, 168, 76, 0.12);
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    border: 1px solid rgba(201, 168, 76, 0.25);
  }

  /* Contact */
  .contact-card {
    padding: 1.5rem;
  }

  .contact-card h4 {
    margin-bottom: 0.75rem;
  }

  .contact-detail {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  .contact-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gold-dark);
    flex-shrink: 0;
    width: 3rem;
  }

  /* Gallery */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  @media (min-width: 640px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .gallery-item {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--brown-light);
    aspect-ratio: 4 / 3;
    background: var(--brown-dark);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.04);
  }

  /* Other disciplines links */
  .discipline-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
  }
</style>
