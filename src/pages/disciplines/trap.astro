---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroVideo from '../../components/HeroVideo.astro';
---

<BaseLayout
  title="Trap Shooting"
  description="Trap shooting at Otter Valley — four fields with automatic traps, Tuesday night league, Southern Counties inter-club competition."
>

  <HeroVideo
    compact={true}
    title="Trap Shooting"
    tagline="Four fields. One target. Pure focus."
    backgroundImage="/images/club/trap-field-01.jpg"
  />

  <!-- Overview -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">About Our Trap Fields</h2>
      <hr class="gold-divider" />
      <p style="max-width: 750px; margin: 0 auto 1rem;">
        Otter Valley's four trap fields feature automatic traps with voice-activated releases, giving shooters a true competition-grade experience. The program has produced competitive shooters at every level and hosts registered competitions annually, drawing participants from across Elgin County and beyond.
      </p>
      <p style="max-width: 750px; margin: 0 auto;">
        Whether you're stepping on a trap field for the first time or competing in the Southern Counties Inter-Club league, the trap range at Otter Valley offers a welcoming environment focused on safety, skill, and camaraderie.
      </p>
    </div>
  </section>

  <!-- Facility Specs + Schedule side by side -->
  <section class="section">
    <div class="container">
      <div class="grid-2">

        <div class="card">
          <h3>Facility</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">Fields</td>
                <td>4 trap fields</td>
              </tr>
              <tr>
                <td class="spec-label">Throwers</td>
                <td>Automatic with voice call</td>
              </tr>
              <tr>
                <td class="spec-label">Standard yardage</td>
                <td>16 yards (ATA)</td>
              </tr>
              <tr>
                <td class="spec-label">Handicap yardage</td>
                <td>20 yards (default)</td>
              </tr>
              <tr>
                <td class="spec-label">Competition</td>
                <td>Registered shoots annually</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card">
          <h3>Schedule</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">Summer</td>
                <td>Wednesday 1:00 PM</td>
              </tr>
              <tr>
                <td class="spec-label">Summer</td>
                <td>Sunday 12:00 noon</td>
              </tr>
              <tr>
                <td class="spec-label">Winter (after time change)</td>
                <td>Sunday 12:00 noon</td>
              </tr>
              <tr>
                <td class="spec-label">Inter-Club weeks</td>
                <td>Saturday (Southern Counties)</td>
              </tr>
              <tr>
                <td class="spec-label">Inter-Club competition</td>
                <td>Sunday 10:00 AM</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </section>

  <!-- Costs -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Costs & Fees</h2>
      <hr class="gold-divider" />
      <div class="grid-2" style="max-width: 900px; margin: 0 auto;">

        <div class="card">
          <h3>Practice Rounds</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">Adults</td>
                <td>$6.00 per round</td>
              </tr>
              <tr>
                <td class="spec-label">Juniors</td>
                <td>$3.00 per round</td>
              </tr>
              <tr>
                <td class="spec-label">Youth (under 18)</td>
                <td>Free targets</td>
              </tr>
              <tr>
                <td class="spec-label">Practice fee</td>
                <td>$7.00</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card">
          <h3>Inter-Club Days</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">Daily targets</td>
                <td>$25.00</td>
              </tr>
              <tr>
                <td class="spec-label">High Score jackpot</td>
                <td>$10.00</td>
              </tr>
              <tr>
                <td class="spec-label">Daily High Gun</td>
                <td>$10.00</td>
              </tr>
              <tr>
                <td class="spec-label">Daily Lewis</td>
                <td>$10.00</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </section>

  <!-- Southern Counties Inter-Club League -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Southern Counties Inter-Club League</h2>
      <hr class="gold-divider" />
      <p style="max-width: 750px; margin: 0 auto 2rem;">
        Every winter, Otter Valley competes alongside five other clubs in the Southern Counties Inter-Club league. Competitions run on Sundays at 10:00 AM throughout the season, with each shooter firing 50 targets — 25 from 16 yards and 25 from handicap yardage (20 yards default). The top five individual scores from each club count toward the team total.
      </p>

      <div class="grid-3">
        <div class="card text-center">
          <div class="stat-number">6</div>
          <div class="stat-label">Participating Clubs</div>
        </div>
        <div class="card text-center">
          <div class="stat-number">50</div>
          <div class="stat-label">Targets Per Match</div>
        </div>
        <div class="card text-center">
          <div class="stat-number">5</div>
          <div class="stat-label">Scores Count Per Club</div>
        </div>
      </div>

      <div class="card champions-card" style="max-width: 600px; margin: 2rem auto 0;">
        <h3 class="text-center">2025 Champions</h3>
        <hr class="gold-divider" style="margin: 1rem 0;" />
        <table>
          <tbody>
            <tr>
              <td class="spec-label">Club Champion</td>
              <td>John Konigshofer</td>
            </tr>
            <tr>
              <td class="spec-label">High 16</td>
              <td>Keith Saunders</td>
            </tr>
            <tr>
              <td class="spec-label">High Handicap</td>
              <td>Bob Morphy</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Rules & Safety -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Range Rules & Safety</h2>
      <hr class="gold-divider" />
      <div class="grid-2" style="max-width: 900px; margin: 0 auto;">
        <div>
          <h4>Firearms & Ammunition</h4>
          <ul class="rules-list">
            <li>Approved shotguns only — no rifles or handguns on trap fields</li>
            <li>12-gauge or 20-gauge shotshells</li>
            <li>Maximum 1-1/8 oz shot, 3-1/4 dram equivalent</li>
            <li>Shot sizes #7.5, #8, or #9 only</li>
            <li>No steel shot on trap fields</li>
          </ul>
        </div>
        <div>
          <h4>Range Conduct</h4>
          <ul class="rules-list">
            <li>Hearing and eye protection mandatory at all times on the line</li>
            <li>Keep action open and unloaded when not on the firing line</li>
            <li>Muzzle pointed downrange or skyward at all times</li>
            <li>Wait for "pull" command before calling for target</li>
            <li>Range Safety Officer instructions are final</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Gallery</h2>
      <hr class="gold-divider" />
      <div class="gallery-grid">
        <div class="gallery-item">
          <img src="/images/club/trap-field-01.jpg" alt="Trap field at Otter Valley Rod & Gun Club" loading="lazy" />
        </div>
      </div>
      <p class="text-center gallery-note">More photos coming soon — contact us to submit your range day photos.</p>
    </div>
  </section>

  <!-- Contact -->
  <section class="section section-dark">
    <div class="container text-center">
      <h2>Contact Trap Committee</h2>
      <hr class="gold-divider" />
      <p>Questions about trap shooting, the inter-club league, or registering for a competition? Reach out to any of our trap committee members.</p>
      <div class="grid-3 contact-grid" style="max-width: 800px; margin: 2rem auto;">
        <div class="card text-center">
          <h4>William Toronyi</h4>
          <a href="tel:5198424360" class="contact-phone">519-842-4360</a>
        </div>
        <div class="card text-center">
          <h4>Bob Vanbelois</h4>
          <a href="tel:5195500434" class="contact-phone">519-550-0434</a>
        </div>
        <div class="card text-center">
          <h4>Bill Malcolm</h4>
          <a href="tel:5196498364" class="contact-phone">519-649-8364</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Disciplines -->
  <section class="section">
    <div class="container text-center">
      <h2>Explore Other Disciplines</h2>
      <hr class="gold-divider" />
      <div class="discipline-links">
        <a href="/disciplines/sporting-clays/" class="btn btn-gold">Sporting Clays</a>
        <a href="/disciplines/rifle/" class="btn btn-gold">Rifle</a>
        <a href="/disciplines/handgun/" class="btn btn-gold">Handgun</a>
        <a href="/disciplines/archery/" class="btn btn-gold">Archery</a>
        <a href="/disciplines/fishing/" class="btn btn-gold">Fishing Pond</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .spec-label {
    color: var(--gold);
    font-weight: 600;
    white-space: nowrap;
    width: 40%;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 3rem;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cream);
    opacity: 0.8;
  }

  .rules-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  .rules-list li {
    padding: 0.4rem 0 0.4rem 1.4rem;
    position: relative;
    color: var(--cream);
    border-bottom: 1px solid rgba(93, 64, 55, 0.3);
    font-size: 0.95rem;
  }

  .rules-list li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: 700;
  }

  h4 {
    color: var(--gold-light);
    margin-bottom: 0.25rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .gallery-item {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--brown-light);
  }

  .gallery-item img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  .gallery-note {
    margin-top: 1.5rem;
    opacity: 0.6;
    font-size: 0.9rem;
    font-style: italic;
  }

  .contact-phone {
    display: block;
    margin-top: 0.4rem;
    font-size: 1.05rem;
    color: var(--gold);
    font-family: var(--font-mono);
  }

  .contact-phone:hover {
    color: var(--gold-light);
  }

  .discipline-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
  }
</style>
