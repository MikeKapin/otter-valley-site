---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroVideo from '../../components/HeroVideo.astro';
---

<BaseLayout
  title="Sporting Clays"
  description="Sporting clays at Otter Valley — 13 stations through wooded terrain, regularly updated target presentations."
>

  <HeroVideo
    compact={true}
    title="Sporting Clays"
    tagline="10 stations through 50 acres of Ontario woodland."
    backgroundImage="/images/stock/sporting-clays-01.svg"
  />

  <!-- Overview -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">About the Course</h2>
      <hr class="gold-divider" />
      <p style="max-width: 750px; margin: 0 auto 1rem;">
        Otter Valley's sporting clays course winds through 50 acres of Ontario woodland, presenting shooters with the most varied and challenging clay target experience available at the club. Thirteen stations — two automatic traps each — deliver a rotating mix of crossing shots, incoming birds, rabbits, and chandelles that reward genuine shooting skill over pattern memorization.
      </p>
      <p style="max-width: 750px; margin: 0 auto;">
        Most stations throw eight targets per shooter; a couple of stations run six-bird presentations for complete 100-target rounds. The committee continually changes target angles and trajectories to keep the course fresh for regular members and competitive for returning visitors.
      </p>
      <div class="notice-box" style="max-width: 750px; margin: 2rem auto 0;">
        <span class="notice-icon">&#9888;</span>
        <strong>Accessibility Note:</strong> The sporting clays course is <strong>not</strong> handicap accessible. The terrain includes uneven ground, tree roots, and elevation changes throughout the 50-acre layout.
      </div>
    </div>
  </section>

  <!-- Facility Specs + Schedule side by side -->
  <section class="section">
    <div class="container">
      <div class="grid-2">

        <div class="card">
          <h3>Course Details</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">Stations</td>
                <td>13 stations</td>
              </tr>
              <tr>
                <td class="spec-label">Traps per station</td>
                <td>2 automatic</td>
              </tr>
              <tr>
                <td class="spec-label">Targets per station</td>
                <td>8 birds (some 6-bird)</td>
              </tr>
              <tr>
                <td class="spec-label">Round options</td>
                <td>50 targets or 100 targets</td>
              </tr>
              <tr>
                <td class="spec-label">Direction</td>
                <td>Start any station, move clockwise</td>
              </tr>
              <tr>
                <td class="spec-label">Accessibility</td>
                <td>Not handicap accessible</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card">
          <h3>Schedule</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">Season</td>
                <td>April through December</td>
              </tr>
              <tr>
                <td class="spec-label">Sign-in opens</td>
                <td>8:00 AM</td>
              </tr>
              <tr>
                <td class="spec-label">Sign-in closes</td>
                <td>8:45 AM</td>
              </tr>
              <tr>
                <td class="spec-label">First start time</td>
                <td>9:00 AM</td>
              </tr>
              <tr>
                <td class="spec-label">Second start time</td>
                <td>11:30 AM</td>
              </tr>
              <tr>
                <td class="spec-label">Early shooting</td>
                <td>No shooting before 9:00 AM</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </section>

  <!-- Costs -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Costs & Fees</h2>
      <hr class="gold-divider" />
      <div class="grid-2" style="max-width: 800px; margin: 0 auto;">

        <div class="card">
          <h3>Standard Rounds</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">50 targets</td>
                <td>$30.00</td>
              </tr>
              <tr>
                <td class="spec-label">100 targets</td>
                <td>$40.00</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card">
          <h3>Junior Rates</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">50 targets</td>
                <td>$15.00</td>
              </tr>
              <tr>
                <td class="spec-label">100 targets</td>
                <td>$25.00</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </section>

  <!-- Equipment Requirements -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Equipment Requirements</h2>
      <hr class="gold-divider" />
      <div class="grid-2" style="max-width: 900px; margin: 0 auto;">

        <div class="card">
          <h3>Firearms</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">Gauge</td>
                <td>12-gauge or 20-gauge</td>
              </tr>
              <tr>
                <td class="spec-label">Action types</td>
                <td>O/U, Side x Side, Semi-Auto, or Pump</td>
              </tr>
              <tr>
                <td class="spec-label">Minimum shells</td>
                <td>2 shells loaded at a time</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="card">
          <h3>Ammunition</h3>
          <hr class="gold-divider" style="margin: 1rem 0;" />
          <table>
            <tbody>
              <tr>
                <td class="spec-label">Shell length</td>
                <td>2-3/4" target loads</td>
              </tr>
              <tr>
                <td class="spec-label">Shot sizes</td>
                <td>#7.5, #8, or #9 only</td>
              </tr>
              <tr>
                <td class="spec-label">Max shot load</td>
                <td>1-1/8 oz</td>
              </tr>
              <tr>
                <td class="spec-label">Max dram equiv.</td>
                <td>3-1/4 dram</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>

      <div class="card safety-card" style="max-width: 600px; margin: 2rem auto 0;">
        <h3 class="text-center">Mandatory Safety Equipment</h3>
        <hr class="gold-divider" style="margin: 1rem 0;" />
        <div class="safety-items">
          <div class="safety-item">
            <span class="safety-check">&#10003;</span>
            <span>Hearing protection — required at all stations</span>
          </div>
          <div class="safety-item">
            <span class="safety-check">&#10003;</span>
            <span>Eye protection — required at all stations</span>
          </div>
          <div class="safety-item">
            <span class="safety-check">&#10003;</span>
            <span>Closed-toe footwear recommended for wooded terrain</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Range Rules -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Range Rules & Conduct</h2>
      <hr class="gold-divider" />
      <div class="grid-2" style="max-width: 900px; margin: 0 auto;">
        <div>
          <h4>On the Course</h4>
          <ul class="rules-list">
            <li>Sign in at the clubhouse before heading to the course</li>
            <li>Start on any available station and proceed clockwise</li>
            <li>No shooting before 9:00 AM regardless of sign-in time</li>
            <li>Groups of 4–6 shooters per station maximum</li>
            <li>Yield the station to groups coming from behind when you have cleared</li>
          </ul>
        </div>
        <div>
          <h4>Firearms Handling</h4>
          <ul class="rules-list">
            <li>Keep action open and unloaded while moving between stations</li>
            <li>Never load more than 2 shells at any time</li>
            <li>Muzzle pointed skyward or downrange at all times</li>
            <li>Call for target only when ready and in shooting position</li>
            <li>Range Safety Officer and course marshals have final authority</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Gallery</h2>
      <hr class="gold-divider" />
      <div class="gallery-grid">
        <div class="gallery-item">
          <img src="/images/club/sporting-clays-01.jpg" alt="Sporting clays station at Otter Valley" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/club/sporting-clays-02.jpg" alt="Wooded sporting clays course at Otter Valley" loading="lazy" />
        </div>
      </div>
      <p class="text-center gallery-note">More photos coming soon — contact us to submit your range day photos.</p>
    </div>
  </section>

  <!-- Other Disciplines -->
  <section class="section section-dark">
    <div class="container text-center">
      <h2>Explore Other Disciplines</h2>
      <hr class="gold-divider" />
      <div class="discipline-links">
        <a href="/disciplines/trap/" class="btn btn-gold">Trap Shooting</a>
        <a href="/disciplines/rifle/" class="btn btn-gold">Rifle</a>
        <a href="/disciplines/handgun/" class="btn btn-gold">Handgun</a>
        <a href="/disciplines/archery/" class="btn btn-gold">Archery</a>
        <a href="/disciplines/fishing/" class="btn btn-gold">Fishing Pond</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .spec-label {
    color: var(--gold);
    font-weight: 600;
    white-space: nowrap;
    width: 45%;
  }

  .notice-box {
    background: rgba(139, 0, 0, 0.15);
    border: 1px solid rgba(139, 0, 0, 0.4);
    border-left: 4px solid var(--red-cta);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    color: var(--cream);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .notice-icon {
    margin-right: 0.5rem;
    color: var(--yellow);
    font-size: 1.1rem;
  }

  .safety-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .safety-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--cream);
    font-size: 0.95rem;
  }

  .safety-check {
    color: var(--green);
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .rules-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  .rules-list li {
    padding: 0.4rem 0 0.4rem 1.4rem;
    position: relative;
    color: var(--cream);
    border-bottom: 1px solid rgba(93, 64, 55, 0.3);
    font-size: 0.95rem;
  }

  .rules-list li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: 700;
  }

  h4 {
    color: var(--gold-light);
    margin-bottom: 0.25rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .gallery-item {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--brown-light);
  }

  .gallery-item img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  .gallery-note {
    margin-top: 1.5rem;
    opacity: 0.6;
    font-size: 0.9rem;
    font-style: italic;
  }

  .discipline-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
  }
</style>
