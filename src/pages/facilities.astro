---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import RangeStatus from '../components/RangeStatus.astro';
import disciplines from '../data/disciplines.json';
---

<BaseLayout
  title="Ranges & Facilities"
  description="Explore the ranges and facilities at Otter Valley Rod & Gun Club — rifle, pistol, trap, sporting clays, archery, and fishing."
>

  <HeroVideo
    compact={true}
    title="Ranges & Facilities"
    tagline="50 Acres of World-Class Facilities"
    backgroundImage="/images/club/grounds-aerial-01.jpg"
  />

  <!-- Property Overview -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">The Property</h2>
      <hr class="gold-divider" />
      <div class="overview-grid grid-2">
        <div class="overview-text">
          <p>
            Set on 50 acres of wooded Ontario countryside along Plank Road between Eden and
            Straffordville, Otter Valley Rod &amp; Gun Club offers one of the most complete
            shooting sports facilities in southwestern Ontario. The natural terrain — mixed
            hardwood forest, open fields, and a stocked pond — is more than a backdrop; it
            defines the character of every range and course on the property.
          </p>
          <p>
            At the heart of the property stands the clubhouse — a fully equipped gathering
            space with a kitchen, meeting area, and comfortable lounge. It serves as the
            hub for league nights, club events, safety briefings, and member socializing
            throughout the season.
          </p>
          <p>
            From the 200-yard rifle range to the winding 10-station sporting clays course,
            every facility here was built and is maintained by club members who take genuine
            pride in what they have created together.
          </p>
        </div>
        <div class="overview-stats">
          <div class="stat-card card">
            <div class="stat-number">50</div>
            <div class="stat-label">Acres</div>
          </div>
          <div class="stat-card card">
            <div class="stat-number">6</div>
            <div class="stat-label">Disciplines</div>
          </div>
          <div class="stat-card card">
            <div class="stat-number">13</div>
            <div class="stat-label">Clays Stations</div>
          </div>
          <div class="stat-card card">
            <div class="stat-number">200</div>
            <div class="stat-label">Yard Rifle Range</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Range Status -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Today's Range Status</h2>
      <hr class="gold-divider" />
      <div class="range-status-wrap">
        <RangeStatus />
        <p class="range-note">
          Range status is updated by club officers. Always verify posted signs on arrival.
          If in doubt, check with the range officer on duty before proceeding.
        </p>
      </div>
    </div>
  </section>

  <!-- Per-Range Spec Cards -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Range Specifications</h2>
      <hr class="gold-divider" />
      <div class="grid-3 specs-grid">
        {disciplines.map((d) => (
          <div class="card spec-card">
            <div class="spec-img-wrap">
              <img
                src={d.image}
                alt={d.name + ' at Otter Valley Rod & Gun Club'}
                loading="lazy"
                class="spec-img"
              />
            </div>
            <div class="spec-body">
              <h3>{d.name}</h3>
              <p class="spec-tagline">{d.tagline}</p>
              <hr class="gold-divider-wide" />
              <ul class="spec-list">
                {Object.entries(d.specs).map(([key, val]) => (
                  <li>
                    <span class="spec-key">{key.charAt(0).toUpperCase() + key.slice(1)}:</span>
                    <span class="spec-val">{val}</span>
                  </li>
                ))}
                <li>
                  <span class="spec-key">Hours:</span>
                  <span class="spec-val">{d.hours}</span>
                </li>
              </ul>
              <a href={`/disciplines/${d.slug}/`} class="btn btn-gold spec-btn">
                Learn More
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Location & Map -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Location</h2>
      <hr class="gold-divider" />
      <div class="location-grid grid-2">
        <div class="location-info">
          <div class="card location-card">
            <h4>Address</h4>
            <p>
              9908 Plank Road<br />
              Straffordville, Ontario<br />
            </p>
            <p class="location-note">
              Located on the east side of Plank Road (formerly Hwy&nbsp;#19),
              between the communities of Eden and Straffordville in Elgin County.
            </p>
            <hr class="gold-divider-wide" />
            <h4>Driving Directions</h4>
            <p>
              From Tillsonburg, head south on Highway&nbsp;19. The club entrance is on
              the east side of Plank Road, well-signed from the road.
              From Aylmer, head west on Imperial Road and turn south on Plank Road.
            </p>
            <hr class="gold-divider-wide" />
            <h4>Parking</h4>
            <p>
              Ample gravel parking is available at the clubhouse. Additional overflow
              parking is available near the trap fields during larger events.
            </p>
          </div>
        </div>
        <div class="map-wrap">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2924.5!2d-80.6!3d42.62!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDLCsDM3JzEyLjAiTiA4MMKwMzYnMDAuMCJX!5e0!3m2!1sen!2sca!4v1234567890"
            width="100%"
            height="100%"
            style="border: 0; display: block; min-height: 380px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Otter Valley Rod &amp; Gun Club Location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Accessibility -->
  <section class="section section-dark">
    <div class="container">
      <div class="accessibility-block">
        <div class="accessibility-icon" aria-hidden="true">&#9854;</div>
        <div>
          <h2>Accessibility</h2>
          <hr class="gold-divider" style="margin-left: 0;" />
          <p>
            The clubhouse and many of the shooting facilities at Otter Valley Rod &amp; Gun
            Club are handicap accessible. Significant accessibility upgrades were completed
            in 2007&ndash;2008 with generous support from the <strong>Ontario Trillium Foundation</strong>,
            ensuring that members and visitors of all abilities can participate fully in
            club activities.
          </p>
          <p>
            Please note that the <strong>Sporting Clays course is not handicap accessible</strong>
            due to the natural woodland terrain. Members with accessibility requirements are
            encouraged to contact us ahead of their visit so we can make appropriate arrangements
            for any other facilities.
          </p>
          <p>
            Questions? Reach us at <a href="mailto:ovrag@hotmail.com">ovrag@hotmail.com</a>
            and we will be happy to assist.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Facility Map Placeholder -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Facility Map</h2>
      <hr class="gold-divider" />
      <div class="map-placeholder-wrap">
        <div class="map-placeholder-video">
          <div class="map-placeholder-inner">
            <div class="map-placeholder-icon" aria-hidden="true">&#9781;</div>
            <p class="map-placeholder-title">Interactive Animated Facility Map</p>
            <p class="map-placeholder-sub">Coming Soon</p>
            <p class="map-placeholder-body">
              A full interactive map of the 50-acre property — showing all ranges, the
              clubhouse, parking areas, the fishing pond, and the sporting clays course
              layout — is currently in development.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rules CTA -->
  <section class="section section-dark">
    <div class="container text-center">
      <h2>Know the Rules Before You Shoot</h2>
      <hr class="gold-divider" />
      <p class="rules-body">
        Every range at Otter Valley operates under a clear set of safety rules. Before
        using any range or facility, please take a moment to review our Rules &amp; Safety
        guidelines. Safety is everyone's responsibility.
      </p>
      <a href="/rules/" class="btn btn-gold">View Rules &amp; Safety</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Overview section */
  .overview-grid {
    align-items: start;
    gap: 3rem;
    margin-top: 1rem;
  }

  .overview-text p {
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1.2rem;
  }

  .overview-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .stat-card {
    text-align: center;
    padding: 1.75rem 1rem;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .stat-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cream);
    opacity: 0.7;
  }

  /* Range status wrapper */
  .range-status-wrap {
    max-width: 700px;
    margin: 0 auto;
  }

  .range-note {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--cream);
    opacity: 0.6;
    text-align: center;
    font-style: italic;
    line-height: 1.6;
  }

  /* Specs grid */
  .specs-grid {
    margin-top: 2.5rem;
  }

  .spec-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .spec-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.45);
  }

  .spec-img-wrap {
    width: 100%;
    height: 180px;
    overflow: hidden;
    background: var(--brown-dark);
    flex-shrink: 0;
  }

  .spec-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }

  .spec-card:hover .spec-img {
    transform: scale(1.04);
  }

  .spec-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .spec-body h3 {
    font-size: 1.15rem;
    color: var(--gold);
    margin: 0 0 0.2rem;
  }

  .spec-tagline {
    font-size: 0.85rem;
    color: var(--cream);
    opacity: 0.65;
    margin: 0 0 0.75rem;
    font-style: italic;
  }

  .spec-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .spec-list li {
    font-size: 0.88rem;
    display: flex;
    gap: 0.4rem;
  }

  .spec-key {
    color: var(--gold-dark);
    font-weight: 600;
    white-space: nowrap;
  }

  .spec-val {
    color: var(--cream);
    opacity: 0.85;
  }

  .spec-btn {
    align-self: flex-start;
    margin-top: auto;
    padding-top: 0.6rem;
  }

  /* Location section */
  .location-grid {
    align-items: stretch;
    gap: 2.5rem;
    margin-top: 1rem;
  }

  .location-card {
    height: 100%;
  }

  .location-card h4 {
    color: var(--gold);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  .location-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }

  .location-note {
    font-size: 0.83rem !important;
    color: var(--gold-dark);
    font-style: italic;
  }

  .map-wrap {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--brown-light);
    min-height: 380px;
  }

  /* Accessibility */
  .accessibility-block {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    max-width: 820px;
    margin: 0 auto;
  }

  .accessibility-icon {
    font-size: 3rem;
    color: var(--gold);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .accessibility-block p {
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .accessibility-block p:last-child {
    margin-bottom: 0;
  }

  .accessibility-block strong {
    color: var(--gold-dark);
  }

  /* Facility map placeholder */
  .map-placeholder-wrap {
    max-width: 900px;
    margin: 2rem auto 0;
  }

  .map-placeholder-video {
    width: 100%;
    aspect-ratio: 16 / 7;
    background: var(--brown-dark);
    border: 1px solid var(--brown-light);
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .map-placeholder-inner {
    text-align: center;
    padding: 2rem;
    max-width: 480px;
  }

  .map-placeholder-icon {
    font-size: 3.5rem;
    color: var(--gold-dark);
    opacity: 0.4;
    margin-bottom: 1rem;
    display: block;
  }

  .map-placeholder-title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--gold);
    margin: 0 0 0.25rem;
  }

  .map-placeholder-sub {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold-dark);
    margin: 0 0 1rem;
    opacity: 0.7;
  }

  .map-placeholder-body {
    font-size: 0.9rem;
    color: var(--cream);
    opacity: 0.55;
    line-height: 1.65;
    margin: 0;
  }

  /* Rules CTA */
  .rules-body {
    max-width: 620px;
    margin: 0 auto 2rem;
    font-size: 1.05rem;
    line-height: 1.75;
    opacity: 0.9;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .overview-grid {
      gap: 2rem;
    }

    .overview-stats {
      grid-template-columns: 1fr 1fr;
      gap: 0.9rem;
    }

    .stat-number {
      font-size: 2.2rem;
    }

    .accessibility-block {
      flex-direction: column;
      gap: 1rem;
    }

    .accessibility-icon {
      font-size: 2.5rem;
    }

    .location-grid {
      gap: 2rem;
    }

    .map-placeholder-video {
      aspect-ratio: 4 / 3;
    }
  }
</style>
