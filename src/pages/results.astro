---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
---

<BaseLayout
  title="Results & Leaderboards"
  description="Competition results and leaderboards from Otter Valley Rod & Gun Club."
>

  <HeroVideo
    compact
    title="Results & Leaderboards"
    tagline="See Where You Stand"
  />

  <!-- Filter / Jump Nav -->
  <section class="section section-dark">
    <div class="container text-center">
      <h2>Competition Results</h2>
      <hr class="gold-divider" />
      <p style="max-width: 640px; margin: 0 auto 2.5rem;">
        Browse official results from the CAN-AM Shoot, weekly Trap League standings,
        and the annual Club Championship. Use the cards below to jump directly to each section.
      </p>
      <div class="jump-nav grid-3">
        <a href="#can-am" class="card jump-card">
          <span class="jump-icon">&#127942;</span>
          <h3>CAN-AM Results</h3>
          <p>Annual international trap & skeet competition results.</p>
        </a>
        <a href="#trap-league" class="card jump-card">
          <span class="jump-icon">&#127919;</span>
          <h3>Trap League Standings</h3>
          <p>Weekly league averages and running standings.</p>
        </a>
        <a href="#championships" class="card jump-card">
          <span class="jump-icon">&#127894;</span>
          <h3>Club Championships</h3>
          <p>Annual club champion history across all disciplines.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CAN-AM Results -->
  <section class="section" id="can-am">
    <div class="container">
      <h2 class="text-center">CAN-AM Results</h2>
      <hr class="gold-divider" />
      <p class="section-desc text-center">
        The CAN-AM Winter Sporting Clay League runs annually across six clubs in Ontario and Michigan.
        Visit the <a href="/can-am/">CAN-AM page</a> for the current season schedule and shoot recaps.
      </p>
      <div class="coming-soon-card card text-center">
        <p class="coming-soon-icon">&#128202;</p>
        <h3>Detailed Results Coming Soon</h3>
        <p>Full CAN-AM shoot-by-shoot scores and standings will be posted here once available. Contact Stan Mathews (519-983-2620) for current results.</p>
      </div>
    </div>
  </section>

  <!-- Trap League -->
  <section class="section section-dark" id="trap-league">
    <div class="container">
      <h2 class="text-center">Trap League Standings</h2>
      <hr class="gold-divider" />
      <p class="section-desc text-center">
        Otter Valley runs trap shooting throughout the season — Wednesdays at 1 PM (summer) and Sundays at noon.
        The Southern Counties Inter-Club league runs Sundays at 10 AM during winter.
      </p>
      <div class="coming-soon-card card text-center">
        <p class="coming-soon-icon">&#127919;</p>
        <h3>Standings Coming Soon</h3>
        <p>League standings and weekly averages will be posted here as the season progresses. Contact the trap committee for current information.</p>
      </div>
    </div>
  </section>

  <!-- Club Championships -->
  <section class="section" id="championships">
    <div class="container">
      <h2 class="text-center">Club Championships</h2>
      <hr class="gold-divider" />
      <p class="section-desc text-center">
        Annual champions are recognized across the club's disciplines.
      </p>
      <div class="coming-soon-card card text-center">
        <p class="coming-soon-icon">&#127942;</p>
        <h3>Championship History Coming Soon</h3>
        <p>Past champions and annual results will be published here. 2025 Trap Champion: John Konigshofer | High 16: Keith Saunders | High Handicap: Bob Morphy.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .jump-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding: 2rem 1.5rem;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .jump-card:hover {
    transform: translateY(-4px);
    border-color: var(--gold);
    color: inherit;
  }

  .jump-card h3 {
    font-size: 1.15rem;
    color: var(--gold);
    margin-bottom: 0.25rem;
  }

  .jump-card p {
    font-size: 0.875rem;
    color: var(--cream);
    opacity: 0.8;
    margin: 0;
  }

  .jump-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    display: block;
  }

  .section-desc {
    max-width: 680px;
    margin: 0 auto 2rem;
    opacity: 0.85;
    line-height: 1.7;
  }

  .coming-soon-card {
    max-width: 600px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .coming-soon-icon {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .coming-soon-card h3 {
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .coming-soon-card p:last-child {
    font-size: 0.9rem;
    opacity: 0.75;
    margin-bottom: 0;
  }
</style>
