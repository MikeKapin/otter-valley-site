---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
---

<BaseLayout
  title="Rules & Safety"
  description="Range rules, code of conduct, and safety regulations at Otter Valley Rod & Gun Club."
>

  <HeroVideo
    title="Rules & Safety"
    tagline="Safety First. Always."
    compact={true}
  />

  <!-- Important Notice Banner -->
  <section class="section section-dark">
    <div class="container">
      <div class="notice-card">
        <div class="notice-icon">&#9888;</div>
        <p>
          <strong>All members and guests must follow these rules at all times.</strong>
          Violations may result in removal from the range or membership revocation.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 1: General Code of Conduct -->
  <section class="section">
    <div class="container">
      <h2>1. General Code of Conduct</h2>
      <hr class="gold-divider" style="margin-left: 0;" />
      <ol class="rules-list">
        <li>
          <strong>Obey and support all Range Officer commands.</strong>
          The Range Officer has complete authority on the range at all times.
        </li>
        <li>
          <strong>Eye and ear protection is mandatory</strong> for all shooters and spectators on all shooting ranges. No exceptions.
        </li>
        <li>
          <strong>Maintain muzzle control downrange at all times.</strong>
          Pointing a firearm at another person is a serious violation and grounds for immediate removal.
        </li>
        <li>
          <strong>Only load your firearm on the firing line</strong> when you are ready to shoot.
        </li>
        <li>
          <strong>When cease-fire is called,</strong> immediately unload, prove safe, and open your action. Keep hands off all firearms while others are downrange.
        </li>
        <li>
          <strong>No shooting before 9:00 AM</strong> without Board approval. All shooting ends at dusk.
        </li>
        <li>
          <strong>Members and guests must sign in and out</strong> every visit.
        </li>
        <li>
          <strong>Members must display their range membership cards</strong> on club property at all times.
        </li>
        <li>
          <strong>Clean up after yourself</strong> — remove all targets and deposit shell casings and hulls in the brass buckets provided.
        </li>
        <li>
          <strong>After a misfire or hang-fire,</strong> keep the action closed for 60 seconds with the muzzle pointed safely downrange before opening.
        </li>
        <li>
          <strong>Do not climb the berms.</strong> Berms are range safety infrastructure — walking on them creates hazards and causes erosion.
        </li>
        <li>
          <strong>Do not distract or disrupt other shooters</strong> while they are on the firing line.
        </li>
        <li>
          <strong>Camouflage and military clothing are not permitted</strong> on club grounds, as they reduce visibility and create a safety concern.
        </li>
        <li>
          <strong>Do not discard live rounds</strong> in garbage containers or on the grounds. Deposit at the designated collection points.
        </li>
        <li>
          <strong>All accidents and incidents must be reported in writing</strong> through the relevant Discipline Chairperson to the Board of Directors.
        </li>
      </ol>
    </div>
  </section>

  <!-- Section 2: Guest Policy -->
  <section class="section section-dark">
    <div class="container">
      <h2>2. Guest Policy</h2>
      <hr class="gold-divider" style="margin-left: 0;" />
      <div class="grid-2 guest-grid">
        <div class="card rule-card">
          <div class="rule-num">01</div>
          <h4>Frequency Limit</h4>
          <p>Guests may visit a maximum of <strong>3 times per calendar year</strong> before a membership application is required.</p>
        </div>
        <div class="card rule-card">
          <div class="rule-num">02</div>
          <h4>Supervision Required</h4>
          <p>All guests must be <strong>accompanied by a member at all times</strong> while on club property.</p>
        </div>
        <div class="card rule-card">
          <div class="rule-num">03</div>
          <h4>One Guest Per Member</h4>
          <p>Only <strong>one shooting guest per available member</strong> is permitted at any one time on the range.</p>
        </div>
        <div class="card rule-card">
          <div class="rule-num">04</div>
          <h4>Member Responsibility</h4>
          <p>The sponsoring member is <strong>fully responsible for the safety and conduct</strong> of their guest during the entire visit.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Discipline-Specific Rules -->
  <section class="section">
    <div class="container">
      <h2>3. Discipline-Specific Rules</h2>
      <hr class="gold-divider" style="margin-left: 0;" />
      <p style="max-width: 700px; margin-bottom: 2rem;">
        Each discipline has its own additional rules and safety procedures.
        Select a discipline below to review the specific regulations for that range.
      </p>
      <div class="grid-2 discipline-links">
        <a href="/disciplines/archery/" class="card discipline-link-card">
          <div class="discipline-icon">&#127993;</div>
          <div>
            <h4>Archery</h4>
            <p>3D range, targets, and equipment rules</p>
          </div>
          <span class="link-arrow">&#8594;</span>
        </a>
        <a href="/disciplines/rifle/" class="card discipline-link-card">
          <div class="discipline-icon">&#127919;</div>
          <div>
            <h4>Rifle Range</h4>
            <p>25-yard to 200-yard range regulations</p>
          </div>
          <span class="link-arrow">&#8594;</span>
        </a>
        <a href="/disciplines/trap/" class="card discipline-link-card">
          <div class="discipline-icon">&#9733;</div>
          <div>
            <h4>Trap &amp; Sporting Clays</h4>
            <p>Field rules, ammunition, and procedures</p>
          </div>
          <span class="link-arrow">&#8594;</span>
        </a>
        <a href="/disciplines/pistol/" class="card discipline-link-card">
          <div class="discipline-icon">&#9670;</div>
          <div>
            <h4>Pistol Range</h4>
            <p>Indoor and outdoor pistol range rules</p>
          </div>
          <span class="link-arrow">&#8594;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Section 4: Emergency Procedures -->
  <section class="section section-dark">
    <div class="container">
      <h2>4. Emergency Procedures</h2>
      <hr class="gold-divider" style="margin-left: 0;" />
      <div class="emergency-grid">

        <div class="card emergency-card emergency-primary">
          <div class="emergency-num">&#9742;</div>
          <h3>Call 911</h3>
          <p>In any life-threatening emergency, call <strong>911</strong> immediately. Give the address: <strong>9908 Plank Road, Straffordville, Ontario</strong>.</p>
        </div>

        <div class="card emergency-card">
          <div class="emergency-num">01</div>
          <h4>Report to Range Officer</h4>
          <p>Report all incidents — injuries, near-misses, or equipment failures — to the Range Officer immediately. Do not leave the range until the incident is documented.</p>
        </div>

        <div class="card emergency-card">
          <div class="emergency-num">02</div>
          <h4>First Aid Kits</h4>
          <p>First aid kit locations are posted at the entrance to each range. All Range Officers are trained in basic first aid.</p>
        </div>

        <div class="card emergency-card">
          <div class="emergency-num">03</div>
          <h4>Nearest Hospital</h4>
          <p>
            <strong>Tillsonburg District Memorial Hospital</strong><br />
            167 Rolph Street, Tillsonburg, ON<br />
            <span style="font-size: 0.85rem; color: var(--gold-dark);">Approximately 15 minutes north on Plank Road / Hwy&nbsp;19</span>
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Footer Notice -->
  <section class="section" style="padding-top: 2rem; padding-bottom: 2rem;">
    <div class="container">
      <div class="footer-notice">
        <span class="notice-flag">&#9679;</span>
        No trespassing. No hunting allowed on club grounds.
        <span class="notice-flag">&#9679;</span>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Important Notice */
  .notice-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    background: rgba(139, 0, 0, 0.12);
    border: 2px solid var(--red-cta);
    border-radius: 6px;
    padding: 1.5rem 2rem;
  }

  .notice-icon {
    font-size: 1.75rem;
    color: var(--red-cta);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .notice-card p {
    margin-bottom: 0;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--cream);
  }

  .notice-card strong {
    color: #ff6b6b;
  }

  /* Rules List */
  .rules-list {
    list-style: none;
    counter-reset: rules-counter;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 860px;
  }

  .rules-list li {
    counter-increment: rules-counter;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.1rem 1.25rem;
    background: var(--brown-base);
    border: 1px solid var(--brown-light);
    border-left: 4px solid var(--gold-dark);
    border-radius: 4px;
    color: var(--cream);
    line-height: 1.6;
    transition: border-left-color var(--transition);
  }

  .rules-list li:hover {
    border-left-color: var(--gold);
  }

  .rules-list li::before {
    content: counter(rules-counter, decimal-leading-zero);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--gold);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.15rem;
    min-width: 2rem;
  }

  .rules-list li strong {
    color: var(--gold-light);
  }

  /* Guest Policy Cards */
  .guest-grid {
    align-items: stretch;
  }

  .rule-card {
    position: relative;
    padding-top: 2rem;
  }

  .rule-num {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-family: var(--font-mono);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--brown-light);
    line-height: 1;
    user-select: none;
  }

  .rule-card h4 {
    color: var(--gold);
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }

  .rule-card p {
    margin-bottom: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .rule-card strong {
    color: var(--gold-light);
  }

  /* Discipline Link Cards */
  .discipline-links {
    gap: 1.25rem;
  }

  .discipline-link-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: var(--cream);
    cursor: pointer;
  }

  .discipline-link-card:hover {
    color: var(--cream);
    border-color: var(--gold);
  }

  .discipline-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    color: var(--gold);
  }

  .discipline-link-card h4 {
    color: var(--gold);
    margin-bottom: 0.2rem;
    font-size: 1rem;
  }

  .discipline-link-card p {
    margin-bottom: 0;
    font-size: 0.85rem;
    color: var(--cream);
    opacity: 0.8;
  }

  .link-arrow {
    margin-left: auto;
    font-size: 1.25rem;
    color: var(--gold-dark);
    flex-shrink: 0;
    transition: transform var(--transition), color var(--transition);
  }

  .discipline-link-card:hover .link-arrow {
    transform: translateX(4px);
    color: var(--gold);
  }

  /* Emergency */
  .emergency-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .emergency-card {
    position: relative;
  }

  .emergency-primary {
    background: rgba(139, 0, 0, 0.15);
    border: 2px solid rgba(139, 0, 0, 0.5);
  }

  .emergency-primary h3 {
    color: #ff6b6b;
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }

  .emergency-primary strong {
    color: var(--cream-light);
  }

  .emergency-num {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .emergency-primary .emergency-num {
    color: #ff6b6b;
  }

  .emergency-card h4 {
    color: var(--gold);
    margin-bottom: 0.4rem;
  }

  .emergency-card p {
    margin-bottom: 0;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .emergency-card strong {
    color: var(--gold-light);
  }

  /* Footer Notice */
  .footer-notice {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold-dark);
    padding: 1.25rem;
    border: 1px solid var(--brown-light);
    border-radius: 4px;
    background: var(--brown-dark);
  }

  .notice-flag {
    color: var(--gold);
    margin: 0 0.75rem;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .emergency-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .emergency-primary {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .emergency-primary .emergency-num {
      font-size: 2.5rem;
      flex-shrink: 0;
      margin-bottom: 0;
    }
  }

  @media (max-width: 767px) {
    .notice-card {
      padding: 1.25rem;
    }

    .rules-list li {
      padding: 0.9rem 1rem;
    }
  }
</style>
