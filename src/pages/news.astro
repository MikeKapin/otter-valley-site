---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import newsletters from '../data/newsletters.json';

// Short month + day badge
function badgeMonth(iso: string): string {
  const d = new Date(iso + 'T12:00:00');
  return d.toLocaleDateString('en-US', { month: 'short' });
}
function badgeDay(iso: string): string {
  return String(new Date(iso + 'T12:00:00').getDate());
}

const newsItems = [
  {
    date: '2026-03-29',
    title: 'CAN-AM Results from Four Square',
    category: 'CAN-AM',
    summary: 'Our friends in Michigan had an awesome course set for us to try our skills on. Results and stats from Shoot #4 at Four Square Sportsman\'s Association.',
    links: [
      { label: 'Results & Stats', url: '/docs/can-am/2025-26-Shoot-4-FSQ-Results-and-Stats.pdf' },
      { label: 'Station Scores', url: '/docs/can-am/2025-26-Shoot-4-FSQ-Station-Scores.pdf' },
    ],
  },
  {
    date: '2026-03-16',
    title: 'March 2026 Newsletter',
    category: 'Newsletter',
    summary: 'The March edition of the Otter Valley newsletter is now available.',
    links: [],
  },
  {
    date: '2026-03-02',
    title: 'CAN-AM Shoot Results — Twin Creeks',
    category: 'CAN-AM',
    summary: 'Results from the CAN-AM shoot at Twin Creeks (TWC) on Sunday March 1st. Full results and station scores available.',
    links: [
      { label: 'Results & Stats', url: '/docs/can-am/25-25-Shoot-3-TWC-Results-and-Stats.pdf' },
      { label: 'Station Scores', url: '/docs/can-am/2025-26-Shoot-3-TWC-Station-Scores.pdf' },
    ],
  },
  {
    date: '2026-02-08',
    title: 'CAN-AM Shoot @ Delaware Has Been Rescheduled, Again',
    category: 'CAN-AM',
    summary: 'The Delaware Rod & Gun Club CAN-AM shoot has been rescheduled to April 12, 2026. This is the second reschedule — originally February 1, then February 8, now April 12.',
    links: [
      { label: 'CAN-AM Schedule', url: '/can-am/' },
      { label: 'Registration Form', url: '/docs/can-am/CANAM-Sporting-Clay-Registration-24-25.pdf' },
    ],
  },
  {
    date: '2026-01-31',
    title: 'February 8th Sporting Clays Has Been Canceled',
    category: 'Range Notice',
    summary: 'Due to weather and snow conditions, the February 8th sporting clays shoot has been canceled.',
    links: [],
  },
  {
    date: '2026-01-28',
    title: 'Indoor Range Remains Closed Jan 28th',
    category: 'Range Notice',
    summary: 'The indoor range remains closed on January 28th due to ongoing renovations.',
    links: [],
  },
  {
    date: '2026-01-25',
    title: 'CAN-AM Schedule Change',
    category: 'CAN-AM',
    summary: 'The CAN-AM shoot at Delaware Rod & Gun originally scheduled for February 1 has been moved to February 8.',
    links: [
      { label: 'View Schedule', url: '/can-am/' },
    ],
  },
  {
    date: '2026-01-21',
    title: 'Indoor Range Closure',
    category: 'Range Notice',
    summary: 'The indoor range will be closed January 26-27 for renovations. Please plan accordingly.',
    links: [],
  },
  {
    date: '2026-01-17',
    title: 'January 2026 Newsletter',
    category: 'Newsletter',
    summary: 'The January edition of the Otter Valley newsletter is now available with updates on the new year, CAN-AM schedule, and membership renewals.',
    links: [],
  },
  {
    date: '2026-01-12',
    title: 'CAN-AM Results and Stats after Lambton Sportsman',
    category: 'CAN-AM',
    summary: 'Results and stats from CAN-AM Shoot #2 at Lambton Sportsman Club on January 4th.',
    links: [
      { label: 'Results & Stats', url: '/docs/can-am/25-26-CanAm-Shoot-2-Results-and-Stats.pdf' },
      { label: 'Station Scores', url: '/docs/can-am/25-26-CanAm-Shoot-2-Station-Scores.pdf' },
    ],
  },
];
---

<BaseLayout
  title="News & Newsletter"
  description="News and newsletter archive from the Otter Valley Rod & Gun Club."
>

  <HeroVideo
    compact
    title="News & Newsletter"
    tagline="Stay in the Loop"
  />

  <!-- Latest News -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Latest News & Announcements</h2>
      <hr class="gold-divider" />
      <div class="news-list">
        {newsItems.map((item) => (
          <div class="news-card">
            <div class="news-date-badge">
              <span class="news-month">{badgeMonth(item.date)}</span>
              <span class="news-day">{badgeDay(item.date)}</span>
            </div>
            <div class="news-body">
              <span class={`news-tag tag-${item.category.toLowerCase().replace(/\s+/g, '-')}`}>{item.category}</span>
              <h3 class="news-title">{item.title}</h3>
              <p class="news-summary">{item.summary}</p>
              {item.links && item.links.length > 0 && (
                <div class="news-links">
                  {item.links.map((link) => (
                    <a href={link.url} target={link.url.endsWith('.pdf') ? '_blank' : undefined} rel={link.url.endsWith('.pdf') ? 'noopener' : undefined} class="news-link">{link.label}</a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="section section-dark">
    <div class="container">
      <div class="signup-wrap">
        <div class="signup-text">
          <h2>Stay Connected</h2>
          <hr class="gold-divider" />
          <p>
            Get club updates, event announcements, and range status delivered to your inbox.
            We send a monthly newsletter and occasional urgent notices — no spam, unsubscribe anytime.
          </p>
        </div>
        <div class="signup-form-wrap">
          <form
            name="newsletter-page"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="newsletter-form"
          >
            <input type="hidden" name="form-name" value="newsletter-page" />
            <p class="hidden-field">
              <label>Do not fill this out: <input name="bot-field" /></label>
            </p>
            <div class="form-row">
              <div class="form-group">
                <label for="nl-name">Your Name</label>
                <input
                  type="text"
                  id="nl-name"
                  name="name"
                  placeholder="Jane Smith"
                  required
                />
              </div>
              <div class="form-group">
                <label for="nl-email">Email Address</label>
                <input
                  type="email"
                  id="nl-email"
                  name="email"
                  placeholder="jane@example.com"
                  required
                />
              </div>
            </div>
            <button type="submit" class="btn btn-gold">Subscribe to Newsletter</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Archive -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Newsletter Archive</h2>
      <hr class="gold-divider" />
      <p class="section-intro text-center">
        Past issues of the Otter Valley Rod &amp; Gun Club newsletter.
        Click any issue to view the full edition.
      </p>
      <div class="newsletter-list">
        {newsletters.map((nl) => (
          <div class="nl-card">
            <div class="nl-date-badge">
              <span class="nl-month">{badgeMonth(nl.date)}</span>
              <span class="nl-day">{badgeDay(nl.date)}</span>
            </div>
            <div class="nl-body">
              <span class="nl-tag">Newsletter</span>
              <h3 class="nl-title">{nl.title}</h3>
              <p class="nl-summary">{nl.summary}</p>
            </div>
            <div class="nl-action">
              {nl.url && nl.url !== '#'
                ? <a href={nl.url} class="btn btn-gold" target="_blank" rel="noopener">View</a>
                : <span class="btn btn-gold disabled" aria-disabled="true">Coming Soon</span>
              }
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Facebook Feed -->
  <section class="section section-dark">
    <div class="container text-center">
      <h2>Follow Us on Facebook</h2>
      <hr class="gold-divider" />
      <p class="section-intro" style="max-width: 600px; margin: 0 auto 2rem;">
        The quickest way to stay up to date. Range closures, last-minute event changes,
        and member announcements are posted to Facebook first.
      </p>
      <div class="fb-embed-wrap">
        <iframe
          src="https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2FOtterValleyRodandGunClub%2F&tabs=timeline&width=500&height=600&small_header=false&adapt_container_width=true&hide_cover=false&show_facepile=true&appId"
          width="500"
          height="600"
          style="border: none; overflow: hidden; max-width: 100%;"
          scrolling="no"
          frameborder="0"
          allowfullscreen
          allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
          title="Otter Valley Rod and Gun Club Facebook Page"
          loading="lazy"
        ></iframe>
        <noscript>
          <p>
            <a
              href="https://www.facebook.com/OtterValleyRodandGunClub/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-gold"
            >
              Visit Us on Facebook
            </a>
          </p>
        </noscript>
      </div>
      <p class="fb-fallback">
        If the feed doesn't load,
        <a
          href="https://www.facebook.com/OtterValleyRodandGunClub/"
          target="_blank"
          rel="noopener noreferrer"
        >
          visit our Facebook page directly
        </a>.
      </p>
    </div>
  </section>

  <!-- CAN-AM CTA -->
  <section class="section">
    <div class="container text-center">
      <h2>CAN-AM League Updates</h2>
      <hr class="gold-divider" />
      <p style="max-width: 620px; margin: 0 auto 1.5rem; opacity: 0.8;">
        For the full CAN-AM schedule, shoot results, and registration details, visit the CAN-AM page.
      </p>
      <a href="/can-am/" class="btn btn-gold">View CAN-AM Details</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── News list ──────────────────────────────────── */
  .news-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 860px;
    margin: 2rem auto 0;
  }

  .news-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.25rem;
    background: var(--brown-base);
    border: 1px solid var(--brown-light);
    border-radius: 6px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .news-card:hover {
    transform: translateX(4px);
    border-color: var(--gold-dark);
  }

  .news-date-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 56px;
    padding: 0.5rem 0.4rem;
    background: var(--brown-dark);
    border: 1px solid var(--gold-dark);
    border-radius: 4px;
    flex-shrink: 0;
  }

  .news-month {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .news-day {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1;
  }

  .news-body { flex: 1; min-width: 0; }

  .news-tag {
    display: inline-block;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .tag-can-am {
    background: rgba(201, 168, 76, 0.2);
    color: var(--gold);
  }

  .tag-newsletter {
    background: var(--gold-dark);
    color: var(--brown-darkest);
  }

  .tag-range-notice {
    background: rgba(183, 28, 28, 0.25);
    color: #ef9a9a;
  }

  .news-title {
    font-family: var(--font-heading);
    color: var(--cream);
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }

  .news-summary {
    font-size: 0.85rem;
    opacity: 0.75;
    margin: 0;
    line-height: 1.5;
  }

  .news-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .news-link {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--gold-dark);
    border-radius: 3px;
    color: var(--gold);
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .news-link:hover {
    background: var(--gold);
    color: var(--brown-darkest);
  }

  @media (max-width: 540px) {
    .news-card { flex-direction: column; align-items: flex-start; }
  }

  /* ── Signup section ────────────────────────────── */
  .signup-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .signup-wrap {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .signup-text p {
    margin-top: 1rem;
    opacity: 0.85;
    line-height: 1.7;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 540px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .form-group input {
    padding: 0.6rem 0.85rem;
    background: var(--brown-dark);
    border: 1px solid var(--brown-light);
    border-radius: 4px;
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.2s ease;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--gold-dark);
  }

  .form-group input::placeholder {
    color: var(--cream);
    opacity: 0.35;
  }

  .hidden-field {
    display: none;
  }

  /* ── Newsletter archive ────────────────────────── */
  .section-intro {
    opacity: 0.8;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .newsletter-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 860px;
    margin: 0 auto;
  }

  .nl-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem;
    background: var(--brown-base);
    border: 1px solid var(--brown-light);
    border-radius: 6px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .nl-card:hover {
    transform: translateX(4px);
    border-color: var(--gold-dark);
  }

  .nl-date-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 56px;
    padding: 0.5rem 0.4rem;
    background: var(--brown-dark);
    border: 1px solid var(--gold-dark);
    border-radius: 4px;
    flex-shrink: 0;
  }

  .nl-month {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .nl-day {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1;
  }

  .nl-body {
    flex: 1;
    min-width: 0;
  }

  .nl-tag {
    display: inline-block;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    background: var(--gold-dark);
    color: var(--brown-darkest);
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .nl-title {
    font-family: var(--font-heading);
    color: var(--cream);
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }

  .nl-summary {
    font-size: 0.85rem;
    opacity: 0.75;
    margin: 0;
    line-height: 1.5;
  }

  .nl-action {
    flex-shrink: 0;
  }

  .btn.disabled {
    opacity: 0.45;
    cursor: default;
    pointer-events: none;
  }

  @media (max-width: 540px) {
    .nl-card     { flex-direction: column; align-items: flex-start; }
    .nl-action   { width: 100%; }
    .nl-action .btn { width: 100%; text-align: center; display: block; }
  }

  /* ── Facebook embed ────────────────────────────── */
  .fb-embed-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .fb-fallback {
    font-size: 0.85rem;
    opacity: 0.6;
    margin-top: 0.5rem;
  }
</style>
