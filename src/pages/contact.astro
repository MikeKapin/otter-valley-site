                <a href="mailto:jenhartmann@hotmai.com">jenhartmann@hotmai.com</a>
              </div>
            </div>
            <hr class="gold-divider-wide" />
            <div class="exec-row">
              <span class="exec-role">Secretary</span>
              <div>
                <strong>Ken Allan</strong><br />
                <a href="tel:519-501-5999">519-501-5999</a><br />
                <a href="mailto:kallan77@hotmail.com">kallan77@hotmail.com</a>
              </div>
            </div>
            <hr class="gold-divider-wide" />
            <div class="exec-row">
              <span class="exec-role">Vice President</span>
              <div>
                <strong>Laurie Cook</strong><br />
                <a href="tel:519-842-2075">519-842-2075</a><br />
                <a href="mailto:lwhite16@live.com">lwhite16@live.com</a>
              </div>
            </div>
            <hr class="gold-divider-wide" />
            <div class="exec-row">
              <span class="exec-role">Treasurer</span>
              <div>
                <strong>John Peazel</strong><br />
                <a href="tel:519-688-2023">519-688-2023</a><br />
                <a href="mailto:steel_eyes@hotmail.com">steel_eyes@hotmail.com</a>
              </div>
            </div>
          </div>

          <h3 class="exec-heading" style="margin-top: 1.5rem;">Membership</h3>
          <div class="card exec-card">
            <div class="exec-row">
              <span class="exec-role">Chairman</span>
              <div>
                <strong>Andrew Demaray</strong><br />
                <a href="tel:519-521-8672">519-521-8672</a><br />
                <a href="mailto:andrewdemaray@gmail.com">andrewdemaray@gmail.com</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Directors -->
        <div>
          <h3 class="exec-heading">Directors</h3>
          <div class="card exec-card">
            <div class="dir-group">
              <h4 class="dir-title">At Large</h4>
              <ul class="dir-list">
                <li><strong>Jake Friesen</strong> — <a href="tel:519-983-0371">519-983-0371</a> — <a href="mailto:jakefrie11@hotmail.com">jakefrie11@hotmail.com</a></li>
                <li><strong>Rick Szucsko</strong> — <a href="tel:226-231-3145">226-231-3145</a></li>
                <li><strong>Butch Acre</strong> — <a href="tel:548-888-1636">548-888-1636</a> — <a href="mailto:butch.acre@gmail.com">butch.acre@gmail.com</a></li>
                <li><strong>Ken Burwell</strong> — <a href="tel:519-619-2611">519-619-2611</a></li>
              </ul>
            </div>
            <hr class="gold-divider-wide" />
            <div class="dir-group">
              <h4 class="dir-title">Grounds</h4>
              <ul class="dir-list">
                <li><strong>Michael Gosselin</strong> — <a href="tel:519-688-0061">519-688-0061</a> — <a href="mailto:gosselin2018@rogers.com">gosselin2018@rogers.com</a></li>
              </ul>
            </div>
            <hr class="gold-divider-wide" />
            <div class="dir-group">
              <h4 class="dir-title">Trap</h4>
              <ul class="dir-list">
                <li><strong>Bill Toronyi</strong> <span class="dir-badge">Director</span> — <a href="tel:519-842-4360">519-842-4360</a></li>
                <li><strong>Bob Vanbelois</strong> <span class="dir-badge">Co-Director</span> — <a href="tel:519-842-5896">519-842-5896</a> — <a href="mailto:rvanbelois@gmail.com">rvanbelois@gmail.com</a></li>
                <li><em>Co-Director — Available</em></li>
              </ul>
            </div>
            <hr class="gold-divider-wide" />
            <div class="dir-group">
              <h4 class="dir-title">Handgun</h4>
              <ul class="dir-list">
                <li><strong>Wayne Bell</strong> <span class="dir-badge">Director</span> — <a href="tel:519-863-3400">519-863-3400</a> — <a href="mailto:wgbell45@gmail.com">wgbell45@gmail.com</a></li>
                <li><strong>Bob Rischel</strong> <span class="dir-badge">Co-Director</span> — <a href="tel:519-589-2988">519-589-2988</a> — <a href="mailto:rischel@golden.net">rischel@golden.net</a></li>
                <li><strong>Scott Taylor</strong> <span class="dir-badge">Co-Director</span> — <a href="tel:519-983-8307">519-983-8307</a> — <a href="mailto:scottvstar@hotmail.com">scottvstar@hotmail.com</a></li>
              </ul>
            </div>
            <hr class="gold-divider-wide" />
            <div class="dir-group">
              <h4 class="dir-title">Bench Rest</h4>
              <ul class="dir-list">
                <li><strong>John Hawley</strong> <span class="dir-badge">Director</span> — <a href="tel:226-678-0707">226-678-0707</a> — <a href="mailto:johnhawley223@gmail.com">johnhawley223@gmail.com</a></li>
                <li><strong>Carey Winkworth</strong> <span class="dir-badge">Co-Director</span> — <a href="tel:519-550-0266">519-550-0266</a> — <a href="mailto:cwink21@hotmail.com">cwink21@hotmail.com</a></li>
                <li><em>Co-Director — Available</em></li>
              </ul>
            </div>
            <hr class="gold-divider-wide" />
            <div class="dir-group">
              <h4 class="dir-title">Archery</h4>
              <ul class="dir-list">
                <li><strong>Mark Hopper</strong> <span class="dir-badge">Director</span> — <a href="tel:519-866-5440">519-866-5440</a> — <a href="mailto:hoppermt@outlook.com">hoppermt@outlook.com</a></li>
                <li><strong>Michael Gosselin</strong> <span class="dir-badge">Co-Director</span> — <a href="tel:519-688-0061">519-688-0061</a> — <a href="mailto:gosselin2018@rogers.com">gosselin2018@rogers.com</a></li>
              </ul>
            </div>
            <hr class="gold-divider-wide" />
            <div class="dir-group">
              <h4 class="dir-title">Sporting Clays</h4>
              <ul class="dir-list">
                <li><strong>Stan Matthews</strong> <span class="dir-badge">Director</span> — <a href="tel:519-983-2620">519-983-2620</a> — <a href="mailto:chumlie@outlook.com">chumlie@outlook.com</a></li>
                <li><strong>Paul Medieros</strong> <span class="dir-badge">Co-Director</span></li>
                <li><strong>Rob Jepma</strong> <span class="dir-badge">Co-Director</span> — <a href="tel:519-755-4424">519-755-4424</a> — <a href="mailto:rojep2@gmail.com">rojep2@gmail.com</a></li>
                <li><strong>Butch Acre</strong> <span class="dir-badge">Co-Director</span> — <a href="tel:548-888-1636">548-888-1636</a> — <a href="mailto:butch.acre@gmail.com">butch.acre@gmail.com</a></li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Google Maps Embed -->
  <section class="section" style="padding-top: 0; padding-bottom: 0;">
    <div class="map-container">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2924.5!2d-80.6!3d42.62!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDLCsDM3JzEyLjAiTiA4MMKwMzYnMDAuMCJX!5e0!3m2!1sen!2sca!4v1234567890"
        width="100%"
        height="400"
        style="border: 0; display: block;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Otter Valley Rod &amp; Gun Club Location"
      ></iframe>
    </div>
  </section>

</BaseLayout>

<style>
  .contact-grid {
    align-items: start;
    gap: 3rem;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .required {
    color: var(--red-cta);
    margin-left: 0.2rem;
  }

  .optional {
    color: var(--gold-dark);
    font-size: 0.8rem;
    font-weight: 400;
    margin-left: 0.3rem;
  }

  textarea {
    resize: vertical;
    min-height: 130px;
  }

  .contact-form .btn {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  /* Info Card */
  .contact-info-card {
    margin-bottom: 1.5rem;
  }

  .info-block {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .info-icon {
    font-size: 1.1rem;
    color: var(--gold);
    margin-top: 0.1rem;
    flex-shrink: 0;
    width: 1.5rem;
    text-align: center;
  }

  .info-block h4 {
    color: var(--gold);
    margin-bottom: 0.2rem;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .info-block p {
    margin-bottom: 0;
    font-size: 0.95rem;
  }

  .info-note {
    font-size: 0.82rem;
    color: var(--gold-dark);
    display: block;
    margin-top: 0.25rem;
    font-style: italic;
  }

  .directions-card h4 {
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .directions-card p {
    margin-bottom: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Map */
  .map-container {
    width: 100%;
    overflow: hidden;
    border-top: 2px solid var(--brown-light);
    border-bottom: 2px solid var(--brown-light);
  }

  /* Executive & Directors */
  .exec-grid {
    gap: 2rem;
    align-items: start;
  }

  .exec-heading {
    font-size: 1.15rem;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .exec-card {
    margin-bottom: 0;
  }

  .exec-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .exec-role {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gold-dark);
    font-weight: 600;
    min-width: 6.5rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .exec-row a {
    font-size: 0.9rem;
  }

  .dir-group h4.dir-title {
    color: var(--gold);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }

  .dir-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .dir-list li {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .dir-list li em {
    color: var(--gold-dark);
    font-size: 0.85rem;
  }

  .dir-badge {
    font-size: 0.7rem;
    background: rgba(201, 168, 76, 0.15);
    color: var(--gold-dark);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
    vertical-align: middle;
  }

  @media (max-width: 767px) {
    .contact-grid {
      gap: 2rem;
    }

    .exec-row {
      flex-direction: column;
      gap: 0.25rem;
    }

    .exec-role {
      min-width: auto;
    }
  }
</style>
