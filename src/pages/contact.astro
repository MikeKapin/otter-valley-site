---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
---

<BaseLayout
  title="Contact"
  description="Contact the Otter Valley Rod & Gun Club — 9908 Plank Road, Straffordville, Ontario."
>

  <HeroVideo
    title="Contact Us"
    tagline="Get in Touch"
    compact={true}
  />

  <!-- Contact Form + Info -->
  <section class="section section-dark">
    <div class="container">
      <div class="grid-2 contact-grid">

        <!-- Left: Netlify Contact Form -->
        <div>
          <h2>Send Us a Message</h2>
          <hr class="gold-divider" style="margin-left: 0;" />
          <form
            method="POST"
            data-netlify="true"
            name="contact"
            class="contact-form"
          >
            <input type="hidden" name="form-name" value="contact" />

            <div class="form-group">
              <label for="name">Full Name <span class="required">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Your full name"
                required
              />
            </div>

            <div class="form-group">
              <label for="email">Email Address <span class="required">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="your@email.com"
                required
              />
            </div>

            <div class="form-group">
              <label for="phone">Phone Number <span class="optional">(optional)</span></label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="(519) 555-0000"
              />
            </div>

            <div class="form-group">
              <label for="subject">Subject <span class="required">*</span></label>
              <select id="subject" name="subject" required>
                <option value="" disabled selected>Select a subject&hellip;</option>
                <option value="General Inquiry">General Inquiry</option>
                <option value="Membership">Membership</option>
                <option value="Events">Events</option>
                <option value="Facility Rental">Facility Rental</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Message <span class="required">*</span></label>
              <textarea
                id="message"
                name="message"
                rows="6"
                placeholder="How can we help you?"
                required
              ></textarea>
            </div>

            <button type="submit" class="btn btn-gold">Send Message</button>
          </form>
        </div>

        <!-- Right: Contact Info Card -->
        <div>
          <h2>Club Information</h2>
          <hr class="gold-divider" style="margin-left: 0;" />

          <div class="card contact-info-card">
            <div class="info-block">
              <span class="info-icon">&#9679;</span>
              <div>
                <h4>Address</h4>
                <p>
                  9908 Plank Road<br />
                  Straffordville, Ontario<br />
                  <span class="info-note">Between Eden and Straffordville on Plank Road (formerly Hwy&nbsp;#19)</span>
                </p>
              </div>
            </div>

            <hr class="gold-divider-wide" />

            <div class="info-block">
              <span class="info-icon">&#9993;</span>
              <div>
                <h4>Mailing Address</h4>
                <p>
                  Otter Valley Rod and Gun<br />
                  9908 Plank Road P.O. Box #2<br />
                  Straffordville, Ontario<br />
                  N0J 1Y0
                </p>
              </div>
            </div>

            <hr class="gold-divider-wide" />

            <div class="info-block">
              <span class="info-icon">&#9993;</span>
              <div>
                <h4>Email</h4>
                <p>
                  <a href="mailto:ovrag@hotmail.com">ovrag@hotmail.com</a>
                </p>
              </div>
            </div>

            <hr class="gold-divider-wide" />

            <div class="info-block">
              <span class="info-icon">&#9658;</span>
              <div>
                <h4>Follow Us on Facebook</h4>
                <p>
                  <a
                    href="https://www.facebook.com/OtterValleyRodandGunClub/"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Otter Valley Rod &amp; Gun Club
                  </a>
                </p>
              </div>
            </div>

            <hr class="gold-divider-wide" />

            <div class="info-block">
              <span class="info-icon">&#128336;</span>
              <div>
                <h4>Hours</h4>
                <p>Ranges open — see posted schedule.<br />Clubhouse available for events.</p>
              </div>
            </div>
          </div>

          <!-- Driving Directions -->
          <div class="card directions-card">
            <h4>Driving Directions</h4>
            <p>
              From Tillsonburg, take Highway&nbsp;19 south. The club is on the east side of Plank Road, between Eden and Straffordville.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Executive & Directors -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Executive &amp; Directors</h2>
      <hr class="gold-divider" />

      <div class="grid-2 exec-grid">

        <!-- Executive -->
        <div>
          <h3 class="exec-heading">Executive</h3>
          <div class="card exec-card">
