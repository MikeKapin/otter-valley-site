---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import FAQ from '../components/FAQ.astro';

const faqItems = [
  {
    question: "Do I need a PAL to join?",
    answer:
      "A valid PAL (Possession and Acquisition Licence) is required to use the firearms ranges. Non-PAL members can still access archery and fishing facilities and are welcome to join for those activities.",
  },
  {
    question: "Is there a probationary period?",
    answer:
      "Yes. All new members must complete a mandatory 30-day probation period. Membership cards are issued after probation is completed and rules have been reviewed.",
  },
  {
    question: "What's the difference between Outdoor and Indoor/Outdoor?",
    answer:
      "The Outdoor membership gives you a gate code and access to all outdoor facilities (trap, sporting clays, rifle, archery, fishing) during normal hours (9 AM to sunset). The Indoor/Outdoor membership adds a swipe card for 24/7 access to the clubhouse and indoor range.",
  },
  {
    question: "How do family add-ons work?",
    answer:
      "Family members are direct family — spouse and children under 18. The first additional family member is $25, and each subsequent family member is $15. Junior members (under 18) are exempt from the initiation fee, and if they continue to a regular membership the initiation fee is waived.",
  },
  {
    question: "When are membership fees due?",
    answer:
      "All membership fees are due by November 1st of the renewal year. First-time members and anyone rejoining after their membership has expired must also pay the $100 initiation fee.",
  },
];
---

<BaseLayout
  title="Membership"
  description="Join the Otter Valley Rod & Gun Club — individual, family, junior, and senior memberships available."
>

  <HeroVideo
    compact
    backgroundImage="/images/club/grounds-aerial-01.jpg"
    title="Membership"
    tagline="Become Part of the Tradition"
  />

  <!-- Benefits -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Member Benefits</h2>
      <hr class="gold-divider" />
      <div class="benefits-layout">
        <p class="benefits-intro">
          Membership at Otter Valley Rod &amp; Gun Club means more than range access — it means
          belonging to a community of like-minded people who share your passion for the outdoors,
          safe shooting sports, and Ontario's hunting and fishing traditions.
        </p>
        <ul class="benefits-list">
          <li>
            <span class="benefit-icon" aria-hidden="true">&#10003;</span>
            <span>Full access to all ranges — trap, sporting clays, rifle, handgun, and archery</span>
          </li>
          <li>
            <span class="benefit-icon" aria-hidden="true">&#10003;</span>
            <span>League participation — registered and club-level competitions throughout the season</span>
          </li>
          <li>
            <span class="benefit-icon" aria-hidden="true">&#10003;</span>
            <span>Voting rights at the Annual General Meeting (AGM)</span>
          </li>
          <li>
            <span class="benefit-icon" aria-hidden="true">&#10003;</span>
            <span>Club newsletter — stay informed on events, closures, and range news</span>
          </li>
          <li>
            <span class="benefit-icon" aria-hidden="true">&#10003;</span>
            <span>Use of clubhouse facilities for member and club events</span>
          </li>
          <li>
            <span class="benefit-icon" aria-hidden="true">&#10003;</span>
            <span>Guest privileges — bring a friend or family member up to 3 times per year</span>
          </li>
          <li>
            <span class="benefit-icon" aria-hidden="true">&#10003;</span>
            <span>Community events and socials — year-round gatherings for members and families</span>
          </li>
          <li>
            <span class="benefit-icon" aria-hidden="true">&#10003;</span>
            <span>Access to the stocked fishing pond on the property</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Membership Tiers -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Membership Options</h2>
      <hr class="gold-divider" />
      <div class="grid-2 tiers-grid">

        <div class="card tier-card">
          <div class="tier-header">
            <h3>Outdoor</h3>
            <div class="tier-price">$225<span class="tier-period">/year</span></div>
          </div>
          <hr class="tier-divider" />
          <p>Entry code to the main gate with access to all outdoor facilities during normal hours of operation (9 AM to sunset).</p>
          <ul class="tier-features">
            <li>Gate code access</li>
            <li>Trap, sporting clays, rifle, archery</li>
            <li>Fishing pond access</li>
            <li>9 AM – sunset hours</li>
          </ul>
        </div>

        <div class="card tier-card tier-featured">
          <div class="tier-badge">Full Access</div>
          <div class="tier-header">
            <h3>Indoor / Outdoor</h3>
            <div class="tier-price">$300<span class="tier-period">/year</span></div>
          </div>
          <hr class="tier-divider" />
          <p>Everything in the Outdoor membership plus a swipe card for 24/7 access to the clubhouse and indoor range.</p>
          <ul class="tier-features">
            <li>All outdoor facilities included</li>
            <li>Swipe card for clubhouse &amp; indoor range</li>
            <li>24/7 access</li>
            <li>Full club privileges</li>
          </ul>
        </div>

      </div>

      <div class="additional-fees">
        <h3 class="text-center">Additional Fees</h3>
        <div class="grid-3 fees-grid">
          <div class="card fee-card">
            <div class="fee-amount">$100</div>
            <div class="fee-label">Initiation Fee</div>
            <p>Required for first-time members and anyone rejoining after membership has expired. Spouse must also pay; children under 18 are exempt.</p>
          </div>
          <div class="card fee-card">
            <div class="fee-amount">+$25</div>
            <div class="fee-label">First Family Add-On</div>
            <p>Add a spouse or child under 18. Direct family members only (spouse and children under 18).</p>
          </div>
          <div class="card fee-card">
            <div class="fee-amount">+$15</div>
            <div class="fee-label">Each Additional</div>
            <p>Each subsequent family member after the first. Junior members who continue to regular membership have the initiation fee waived.</p>
          </div>
        </div>
      </div>

      <p class="tiers-note">
        All membership fees are due by November 1st. Prices are subject to change.
        Contact the club for the most current information.
      </p>
    </div>
  </section>

  <!-- Requirements -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="text-center">Membership Requirements</h2>
      <hr class="gold-divider" />
      <div class="requirements-grid grid-3">

        <div class="card req-card">
          <div class="req-icon" aria-hidden="true">&#128220;</div>
          <h3>Valid PAL</h3>
          <p>
            A valid Possession and Acquisition Licence (PAL) issued by the RCMP is required
            to access any firearms range. Bring your PAL card at every visit — you will be
            asked to present it at sign-in.
          </p>
        </div>

        <div class="card req-card">
          <div class="req-icon" aria-hidden="true">&#128203;</div>
          <h3>30-Day Probation</h3>
          <p>
            All new members must complete a mandatory orientation session and a 30-day
            probation period. Membership cards are issued after probation is completed
            and club rules have been reviewed.
          </p>
        </div>

        <div class="card req-card">
          <div class="req-icon" aria-hidden="true">&#128394;</div>
          <h3>Sign-In Required</h3>
          <p>
            Members and guests must sign in at the clubhouse before using any range or
            facility. This requirement is mandatory at every visit and ensures range
            safety and accurate record-keeping for the club.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Frequently Asked Questions</h2>
      <hr class="gold-divider" />
      <FAQ items={faqItems} />
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section section-dark">
    <div class="container text-center">
      <h2>Ready to Apply?</h2>
      <hr class="gold-divider" />
      <p style="max-width: 600px; margin: 0 auto 1.5rem;">
        Have a question or want to get the process started? Reach out to the club directly
        or use the contact form — we'll get back to you promptly.
      </p>
      <div class="cta-group">
        <a href="mailto:ovrag@hotmail.com" class="btn btn-gold">ovrag@hotmail.com</a>
        <a href="/contact/" class="btn btn-gold">Contact Form</a>
        <a href="https://otter-valley-app.pages.dev" target="_blank" class="btn btn-gold">Try Our Member App</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Benefits */
  .benefits-layout {
    max-width: 720px;
    margin: 0 auto;
  }

  .benefits-intro {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.75rem;
    text-align: center;
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .benefits-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--cream);
    padding: 0.6rem 1rem;
    background: rgba(201, 168, 76, 0.05);
    border-left: 2px solid var(--gold-dark);
    border-radius: 0 4px 4px 0;
  }

  .benefit-icon {
    color: var(--gold);
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
    font-weight: 700;
  }

  /* Tier cards */
  .tiers-grid {
    margin-top: 2.5rem;
    gap: 1.5rem;
  }

  .tier-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
  }

  .tier-featured {
    border-color: var(--gold);
    box-shadow: 0 0 0 1px var(--gold-dark), 0 8px 30px rgba(201, 168, 76, 0.15);
  }

  .tier-badge {
    position: absolute;
    top: -1px;
    right: 1.25rem;
    background: var(--gold);
    color: var(--brown-darkest);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.65rem;
    border-radius: 0 0 4px 4px;
  }

  .tier-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .tier-header h3 {
    margin-bottom: 0;
    font-size: 1.4rem;
  }

  .tier-price {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--gold);
    font-weight: 700;
    white-space: nowrap;
  }

  .tier-period {
    font-size: 1rem;
    font-weight: 400;
    opacity: 0.7;
  }

  .tier-divider {
    border: none;
    height: 1px;
    background: var(--brown-light);
    margin: 1rem 0;
  }

  .tier-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    margin-bottom: 1rem;
    flex: 1;
  }

  .tier-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .tier-features li {
    font-size: 0.88rem;
    color: var(--cream);
    padding-left: 1.1rem;
    position: relative;
    opacity: 0.85;
  }

  .tier-features li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--gold-dark);
  }

  .tiers-note {
    text-align: center;
    margin-top: 1.75rem;
    font-size: 0.88rem;
    opacity: 0.65;
    font-style: italic;
  }

  /* Additional fees */
  .additional-fees {
    margin-top: 3rem;
  }

  .additional-fees h3 {
    margin-bottom: 1.5rem;
    color: var(--gold);
  }

  .fees-grid {
    gap: 1.25rem;
  }

  .fee-card {
    text-align: center;
    padding: 1.5rem 1.25rem;
  }

  .fee-amount {
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--gold);
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .fee-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }

  .fee-card p {
    font-size: 0.85rem;
    line-height: 1.55;
    opacity: 0.75;
    margin: 0;
  }

  /* Requirements */
  .requirements-grid {
    margin-top: 2.5rem;
  }

  .req-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .req-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .req-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .req-card p {
    font-size: 0.93rem;
    line-height: 1.65;
    margin-bottom: 0;
  }

  /* CTA group */
  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
