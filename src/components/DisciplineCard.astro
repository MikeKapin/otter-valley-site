---
interface Props {
  name: string;
  slug: string;
  tagline: string;
  image: string;
}

const { name, slug, tagline, image } = Astro.props;
---

<a href={`/disciplines/${slug}/`} class="discipline-card">
  <div class="card-image" style={`background-image: url('${image}');`}></div>
  <div class="card-overlay">
    <h3 class="card-title">{name}</h3>
    <p class="card-tagline">{tagline}</p>
    <span class="card-cta">Explore &rarr;</span>
  </div>
</a>

<style>
  .discipline-card {
    display: block;
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    height: 280px;
    text-decoration: none;
  }

  .card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.5s ease;
  }

  .discipline-card:hover .card-image {
    transform: scale(1.08);
  }

  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(27, 14, 0, 0.9) 0%, rgba(27, 14, 0, 0.4) 60%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    transition: background 0.3s ease;
  }

  .discipline-card:hover .card-overlay {
    background: linear-gradient(to top, rgba(27, 14, 0, 0.95) 0%, rgba(27, 14, 0, 0.5) 70%, rgba(27, 14, 0, 0.2) 100%);
  }

  .card-title {
    font-family: var(--font-heading);
    color: var(--gold);
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .card-tagline {
    color: var(--cream);
    font-size: 0.9rem;
    opacity: 0.85;
    margin: 0;
  }

  .card-cta {
    color: var(--gold);
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 0.5rem;
    opacity: 0;
    transform: translateY(5px);
    transition: all 0.3s ease;
  }

  .discipline-card:hover .card-cta {
    opacity: 1;
    transform: translateY(0);
  }
</style>
