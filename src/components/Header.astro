---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  {
    href: '#',
    label: 'Disciplines',
    children: [
      { href: '/disciplines/trap/', label: 'Trap Shooting' },
      { href: '/disciplines/sporting-clays/', label: 'Sporting Clays' },
      { href: '/disciplines/rifle/', label: 'Rifle' },
      { href: '/disciplines/handgun/', label: 'Handgun' },
      { href: '/disciplines/archery/', label: 'Archery' },
      { href: '/disciplines/fishing/', label: 'Fishing Pond' },
    ],
  },
  { href: '/can-am/', label: 'CAN-AM' },
  { href: '/events/', label: 'Events' },
  { href: '/membership/', label: 'Membership' },
  { href: '/news/', label: 'News' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
      <img src="/images/club/club-logo.jpg" alt="Otter Valley Rod & Gun Club" class="logo" width="50" height="50" />
      <span class="logo-text">Otter Valley</span>
    </a>

    <button class="hamburger" aria-label="Toggle navigation" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li class={`nav-item ${link.children ? 'has-dropdown' : ''}`}>
            <a
              href={link.href}
              class={`nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'active' : ''}`}
            >
              {link.label}
              {link.children && <span class="dropdown-arrow">&#9662;</span>}
            </a>
            {link.children && (
              <ul class="dropdown">
                {link.children.map((child) => (
                  <li>
                    <a href={child.href} class={`dropdown-link ${currentPath === child.href ? 'active' : ''}`}>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <a href="/membership/" class="btn btn-gold nav-cta">Join the Club</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(27, 14, 0, 0.97);
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
    backdrop-filter: blur(10px);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo {
    border-radius: 50%;
    border: 2px solid var(--gold-dark);
  }

  .logo-text {
    font-family: var(--font-heading);
    color: var(--gold);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--cream);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--gold);
  }

  .nav-link.active {
    border-bottom: 2px solid var(--gold);
  }

  .dropdown-arrow {
    font-size: 0.7rem;
    margin-left: 0.25rem;
  }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--brown-dark);
    border: 1px solid rgba(201, 168, 76, 0.2);
    border-radius: 4px;
    min-width: 200px;
    padding: 0.5rem 0;
    list-style: none;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
  }

  .has-dropdown:hover .dropdown {
    display: block;
  }

  .dropdown-link {
    display: block;
    padding: 0.5rem 1.25rem;
    color: var(--cream);
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }

  .dropdown-link:hover,
  .dropdown-link.active {
    color: var(--gold);
    background: rgba(201, 168, 76, 0.1);
  }

  .nav-cta {
    padding: 0.5rem 1.25rem;
    font-size: 0.8rem;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .hamburger-line {
    display: block;
    width: 25px;
    height: 2px;
    background: var(--gold);
    transition: all 0.3s ease;
  }

  @media (max-width: 1024px) {
    .hamburger {
      display: flex;
    }

    .main-nav {
      display: none;
      position: absolute;
      top: 70px;
      left: 0;
      right: 0;
      background: var(--brown-dark);
      border-bottom: 1px solid rgba(201, 168, 76, 0.2);
      flex-direction: column;
      padding: 1rem;
      gap: 0;
    }

    .main-nav.open {
      display: flex;
    }

    .nav-list {
      flex-direction: column;
      width: 100%;
    }

    .nav-link {
      padding: 0.75rem 1rem;
    }

    .dropdown {
      position: static;
      box-shadow: none;
      border: none;
      padding-left: 1rem;
      background: rgba(0, 0, 0, 0.2);
    }

    .has-dropdown .dropdown {
      display: none;
    }

    .has-dropdown.open .dropdown {
      display: block;
    }

    .nav-cta {
      margin-top: 0.5rem;
      text-align: center;
    }
  }
</style>

<script src="/scripts/nav.js" defer></script>
