---
interface Props {
  videoSrc?: string;
  title: string;
  tagline?: string;
  compact?: boolean;
  backgroundImage?: string;
}

const { videoSrc, title, tagline, compact = false, backgroundImage } = Astro.props;
const hasVideo = !!videoSrc;
---

<section class={`video-hero ${compact ? 'compact' : ''}`}>
  {videoSrc ? (
    <video autoplay muted playsinline preload="metadata" class="hero-video">
      <source src={videoSrc} type="video/mp4" />
    </video>
  ) : backgroundImage ? (
    <div class="video-fallback" style={`background-image: url('${backgroundImage}');`}></div>
  ) : (
    <div class="video-fallback animated-bg"></div>
  )}
  {!hasVideo && (
    <div class="video-overlay">
      <h1 class="hero-title">{title}</h1>
      {tagline && <p class="hero-tagline">{tagline}</p>}
      <hr class="gold-divider" />
      <slot />
    </div>
  )}
  {!compact && (
    <div class="scroll-indicator">
      <span class="scroll-arrow">&#8964;</span>
    </div>
  )}
</section>

<style>
  .video-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 500px;
    overflow: hidden;
  }

  .video-hero.compact {
    height: 50vh;
    min-height: 350px;
  }

  .hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-fallback {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }

  .animated-bg {
    background: linear-gradient(
      135deg,
      #1b0e00 0%,
      #2d1b00 25%,
      #3e2723 50%,
      #2d1b00 75%,
      #1b0e00 100%
    );
    background-size: 400% 400%;
    animation: gradientShift 15s ease infinite;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(27, 14, 0, 0.5) 0%,
      rgba(27, 14, 0, 0.3) 40%,
      rgba(27, 14, 0, 0.7) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    color: var(--gold);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
    margin-bottom: 0.5rem;
    animation: fadeUp 1s ease-out;
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    color: var(--cream);
    opacity: 0.9;
    max-width: 600px;
    animation: fadeUp 1s ease-out 0.3s both;
  }

  .gold-divider {
    animation: fadeUp 1s ease-out 0.5s both;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    animation: bounce 2s infinite;
  }

  .scroll-arrow {
    font-size: 2rem;
    color: var(--gold);
    opacity: 0.6;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(10px); }
  }
</style>
