---
---

<div class="calendar-wrapper" id="calendar">
  <p class="cal-loading">Loading calendar...</p>
</div>

<script src="/scripts/calendar.js" defer></script>

<style>
  .calendar-wrapper {
    background: var(--brown-base);
    border: 1px solid var(--brown-light);
    border-radius: 6px;
    padding: 1.5rem;
    position: relative;
  }

  .cal-loading {
    text-align: center;
    color: var(--cream);
    opacity: 0.6;
  }
</style>

<style is:global>
  .cal-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .cal-nav-btn {
    background: none;
    border: 1px solid var(--gold-dark);
    color: var(--gold);
    width: 36px;
    height: 36px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1.5rem;
    line-height: 1;
    transition: all 0.2s ease;
  }

  .cal-nav-btn:hover {
    background: var(--gold);
    color: var(--brown-darkest);
  }

  .cal-month-label {
    font-family: var(--font-heading);
    color: var(--gold);
    font-size: 1.3rem;
    min-width: 200px;
    text-align: center;
  }

  .cal-view-btn {
    background: none;
    border: 1px solid var(--brown-light);
    color: var(--cream);
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.8rem;
    transition: all 0.2s ease;
  }

  .cal-view-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  .cal-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .cal-filter-btn {
    background: none;
    border: 1px solid var(--brown-light);
    color: var(--cream);
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.8rem;
    transition: all 0.2s ease;
  }

  .cal-filter-btn:hover,
  .cal-filter-btn.active {
    border-color: var(--filter-color);
    color: var(--filter-color);
    background: rgba(255, 255, 255, 0.05);
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    background: var(--brown-light);
    border: 1px solid var(--brown-light);
    border-radius: 4px;
    overflow: hidden;
  }

  .cal-day-header {
    background: var(--brown-dark);
    color: var(--gold);
    text-align: center;
    padding: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .cal-day {
    background: var(--brown-darkest);
    min-height: 80px;
    padding: 0.35rem;
    position: relative;
  }

  .cal-day.empty {
    background: rgba(27, 14, 0, 0.5);
  }

  .cal-day.has-events {
    background: rgba(62, 39, 35, 0.6);
  }

  .cal-day-num {
    font-size: 0.8rem;
    color: var(--cream);
    opacity: 0.7;
  }

  .cal-event-dot {
    font-size: 0.65rem;
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    margin-top: 0.15rem;
    cursor: pointer;
    color: var(--brown-darkest);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: opacity 0.2s;
  }

  .cal-event-dot:hover {
    opacity: 0.8;
  }

  .cal-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cal-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: var(--brown-dark);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cal-list-item:hover {
    background: rgba(201, 168, 76, 0.1);
  }

  .cal-list-date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--gold);
    min-width: 60px;
  }

  .cal-list-cat {
    font-size: 0.65rem;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    color: var(--brown-darkest);
    font-weight: 600;
  }

  .cal-list-title {
    color: var(--cream);
    font-size: 0.9rem;
  }

  .cal-empty {
    text-align: center;
    color: var(--cream);
    opacity: 0.5;
    padding: 2rem;
  }

  .cal-detail {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--brown-dark);
    border: 1px solid var(--gold-dark);
    border-radius: 8px;
    padding: 2rem;
    max-width: 400px;
    width: 90%;
    z-index: 100;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
  }

  .cal-detail h3 {
    font-family: var(--font-heading);
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .cal-detail-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: none;
    border: none;
    color: var(--cream);
    font-size: 1.5rem;
    cursor: pointer;
    opacity: 0.6;
  }

  .cal-detail-close:hover {
    opacity: 1;
  }

  .cal-detail-date {
    color: var(--gold-light);
    font-size: 0.9rem;
  }

  .cal-detail-loc {
    font-size: 0.85rem;
    opacity: 0.7;
    font-style: italic;
  }

  .cal-gcal-btn {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.4rem 1rem;
    border: 1px solid var(--gold);
    color: var(--gold);
    border-radius: 3px;
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cal-gcal-btn:hover {
    background: var(--gold);
    color: var(--brown-darkest);
  }

  @media (max-width: 768px) {
    .cal-day {
      min-height: 50px;
      padding: 0.2rem;
    }

    .cal-event-dot {
      font-size: 0;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      padding: 0;
    }
  }
</style>
